# VITRIOL Environment Configuration
# Source this file to set up your environment:
#   source vitriol.env
#
# Or set individual variables before running commands:
#   VITRIOL_MODEL_DIR=/models ./scripts/run_benchmark.sh
#
# See RESOURCE_LOCATIONS.md for detailed documentation.

# === Core Paths ===

# Directory containing model .gguf files
export VITRIOL_MODEL_DIR="${VITRIOL_MODEL_DIR:-/mnt/data/ai/koboldcpp}"

# llama.cpp source + build tree
export VITRIOL_LLAMA_DIR="${VITRIOL_LLAMA_DIR:-/mnt/data/ai/llama.cpp}"

# Large data directory (models, swap, temp)
export VITRIOL_DATA_DIR="${VITRIOL_DATA_DIR:-/mnt/data/ai}"

# Alka language compiler project root
export VITRIOL_ALKA_DIR="${VITRIOL_ALKA_DIR:-$HOME/Desktop/Projects/alka-lang}"

# === Derived Paths (typically don't override) ===

export VITRIOL_LLAMA_BIN="${VITRIOL_LLAMA_BIN:-$VITRIOL_LLAMA_DIR/build/bin}"
export VITRIOL_LLAMA_SERVER="$VITRIOL_LLAMA_BIN/llama-server"
export VITRIOL_ALKA_BIN="${VITRIOL_ALKA_BIN:-$VITRIOL_ALKA_DIR/zig-out/bin/alka}"

# === Default Model Files ===

export VITRIOL_MODEL_35B="${VITRIOL_MODEL_35B:-$VITRIOL_MODEL_DIR/Qwen3.6-35B-A3B-UD-Q2_K_XL.gguf}"
export VITRIOL_MODEL_9B="${VITRIOL_MODEL_9B:-$VITRIOL_MODEL_DIR/Qwen_Qwen3.5-9B-Q4_K_M.gguf}"
export VITRIOL_MODEL_DRAFT="${VITRIOL_MODEL_DRAFT:-$VITRIOL_MODEL_DIR/draft/Qwen3-0.6B-Q4_K_M.gguf}"

# === Runtime Settings ===

# Default port for llama-server
export VITRIOL_PORT="${VITRIOL_PORT:-8279}"

# GPU to use (CUDA_VISIBLE_DEVICES)
export VITRIOL_GPU="${VITRIOL_GPU:-0}"

# Temporary directory for inference artifacts
export VITRIOL_TMP_DIR="${VITRIOL_TMP_DIR:-$VITRIOL_DATA_DIR/tmp}"

# === Alka Integration ===

# Directory containing VITRIOL's Alka recipes and vials
export VITRIOL_ALKA_RECIPES="${VITRIOL_ALKA_RECIPES:-./alka/recipes}"
export VITRIOL_ALKA_VIALS="${VITRIOL_ALKA_VIALS:-./alka/vials}"
export VITRIOL_ALKA_RESULTS="${VITRIOL_ALKA_RESULTS:-./alka/results}"
