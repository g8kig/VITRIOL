tui_server_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Server Settings                 ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Host Address     [${CFG_HOST}]"
        printf "║  %-37s ║\n" "2) Port Number      [${CFG_PORT}]"
        printf "║  %-37s ║\n" "3) Parallel Slots   [${CFG_PARALLEL}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                read -r -p "Enter host address: " val
                if [[ -n "$val" ]]; then
                    config_set server.host "$val"
                fi
                ;;
            2)
                read -r -p "Enter port (1024-65535): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1024 && val <= 65535)); then
                    config_set server.port "$val"
                else
                    echo "Invalid (must be 1024-65535)"; sleep 1
                fi
                ;;
            3)
                read -r -p "Enter parallel slots (1-8): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 8)); then
                    config_set server.parallel "$val"
                else
                    echo "Invalid (must be 1-8)"; sleep 1
                fi
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

# ═════════════════════════════════════════════════════════════════
# RUN & SERVE
# ═════════════════════════════════════════════════════════════════

setup_caps() {
    local bin="${1:-$BINARY}"
    echo "→ Setting CAP_IPC_LOCK on $bin"
    if ! command -v sudo &>/dev/null; then
        echo "  ERROR: sudo not found"
        exit 1
    fi
    sudo setcap cap_ipc_lock=+ep "$bin"
    echo "  ✓ Done"
    getcap "$bin"
    echo ""
    echo "System RAM for page-locking: $(free -g | awk '/^Mem:/{print $2}') GiB total"
    echo "                             $(free -g | awk '/^Mem:/{print int($2*0.8)}') GiB available without swap pressure"
}

usage() {
    print_header
    cat <<'HEREDOC'
  vitriol run [options]      interactive inference session
  vitriol serve [options]    persistent HTTP API server
  vitriol stop               stop running server
  vitriol bench [options]    quick throughput benchmark (uses llama-bench)
  vitriol tui                live dashboard (requires textual Python lib)
  vitriol config             interactive configuration TUI
  vitriol config show        print current configuration
  vitriol config init        create config file with defaults
  vitriol config reset       restore defaults
  vitriol config edit        open config in $EDITOR
  vitriol config set <key> <val>  set a config value
  vitriol setup              set CAP_IPC_LOCK capability
  vitriol help               this message

Run options:
  -m PATH            model file path
  -c N               context window (tokens)
  -t N               CPU threads
  -ngl N             GPU layers to offload
  -lru MB            LRU VRAM cache size
  --memory-mode MODE   emulated memory: on | off
  --kv-mode MODE       KV cache: standard | offload | sparse
  --frozen-prompt M    frozen prompt caching: on | off
  --semantic-mode M    semantic search: on | off (requires sentence-transformers)
  --predictive-prefetch on|off  cross-layer expert prefetch (DMA stream overlap)
  --pin-layers N       pin first N layers' expert tensors in VRAM
  --prune-experts N    drop bottom N of 8 active experts (0-7, experimental)
  --verbose            enable debug logging
  --dry-run            print config without launching

Serve options:
  -m PATH            model file path
  -c N               context window (tokens)
  -t N               CPU threads
  -ngl N             GPU layers to offload
  -lru MB            LRU VRAM cache size
  --host ADDR        bind address (default: $DEFAULT_HOST)
  -port N            server port (default: $DEFAULT_PORT)
  -p N               parallel slots (default: $DEFAULT_PARALLEL)
  --memory-mode MODE   emulated memory: on | off
  --kv-mode MODE       KV cache: standard | offload | sparse
  --frozen-prompt M    frozen prompt caching: on | off
  --semantic-mode M    semantic search: on | off (requires sentence-transformers)
  --detach             run server in background
  --spec-type TYPE     speculative decoding type (mtp, draft, etc.)
  --spec-draft-n-max N number of tokens to draft (e.g. 2 for MTP)
  --pin-layers N       pin first N layers' expert tensors in VRAM
  --prune-experts N    drop bottom N of 8 active experts (0-7, experimental)
  --verbose          enable debug logging
  --dry-run          print config without launching

All options can be persisted via: vitriol config

HEREDOC
}

# ═════════════════════════════════════════════════════════════════
# MAIN
# ═════════════════════════════════════════════════════════════════

# Parse config before command dispatch so env vars override
parse_config

CMD="${1:-help}"
case "$CMD" in
    run)
        shift
        # CLI flags override config
        CLI_MODEL=""
        CLI_CTX=""
        CLI_THREADS=""
        CLI_NGL=""
        CLI_PORT=""
        CLI_LRU_MB=""
        CLI_VERBOSE=""
        CLI_MEMORY_MODE=""
        CLI_KV_MODE=""
        CLI_FROZEN_PROMPT=""
        CLI_SEMANTIC_MODE=""
        CLI_KV_QUANT=""
        CLI_LOOKUP=""
        CLI_ENGINE_MODE=""
        CLI_DISK_OFFLOAD=""
            CLI_SPEC_TYPE=""
            CLI_SPEC_DRAFT_N_MAX=""
            CLI_PIN_LAYERS=""
            CLI_PRUNE_EXPERTS=""
            DRY_RUN=false

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    -m) CLI_MODEL="$2"; shift 2 ;;
                    -c) CLI_CTX="$2"; shift 2 ;;
                    -t) CLI_THREADS="$2"; shift 2 ;;
                    -ngl) CLI_NGL="$2"; shift 2 ;;
                    -lru) CLI_LRU_MB="$2"; shift 2 ;;
                    -port) CLI_PORT="$2"; shift 2 ;;
                    --memory-mode) CLI_MEMORY_MODE="$2"; shift 2 ;;
                    --kv-mode) CLI_KV_MODE="$2"; shift 2 ;;
                    --frozen-prompt) CLI_FROZEN_PROMPT="$2"; shift 2 ;;
                    --semantic-mode) CLI_SEMANTIC_MODE="$2"; shift 2 ;;
                --kv-quant) CLI_KV_QUANT="$2"; shift 2 ;;
                --kv-quant-v) CLI_KV_QUANT_V="$2"; shift 2 ;;
                    --kv-quant-v) CLI_KV_QUANT_V="$2"; shift 2 ;;
                    --lookup) CLI_LOOKUP="$2"; shift 2 ;;
                    --engine-mode) CLI_ENGINE_MODE="$2"; shift 2 ;;
                    --spec-type) CLI_SPEC_TYPE="$2"; shift 2 ;;
                    --spec-draft-n-max) CLI_SPEC_DRAFT_N_MAX="$2"; shift 2 ;;
                    --verbose) CLI_VERBOSE="true"; shift ;;
                    --disk-offload) CLI_DISK_OFFLOAD="1"; shift ;;
                    --pin-layers) CLI_PIN_LAYERS="$2"; shift 2 ;;
                    --prune-experts) CLI_PRUNE_EXPERTS="$2"; shift 2 ;;
                    --dry-run) DRY_RUN=true; shift;;
                    -h|--help) usage; exit 0 ;;
                    *) echo "Unknown: $1"; usage; exit 1 ;;
                esac
            done

        # Precedence: CLI > Config > Env > Default
        MODEL="${VITRIOL_MODEL:-${CLI_MODEL:-${CFG_MODEL}}}"
        CTX="${CLI_CTX:-${CFG_CTX}}"
        THREADS="${CLI_THREADS:-${CFG_THREADS}}"
        NGL="${CLI_NGL:-${CFG_NGL}}"
        PORT="${CLI_PORT:-${CFG_PORT}}"
        LRU_MB="${CLI_LRU_MB:-${CFG_LRU_MB}}"
        MODE="${VITRIOL_MODE:-${CFG_MODE}}"
        MEMORY_MODE="${VITRIOL_MEMORY_MODE:-${CLI_MEMORY_MODE:-${CFG_MEMORY_MODE}}}"
        KV_MODE="${VITRIOL_KV_MODE:-${CLI_KV_MODE:-${CFG_KV_MODE}}}"
        FROZEN_PROMPT="${VITRIOL_FROZEN_PROMPT:-${CLI_FROZEN_PROMPT:-${CFG_FROZEN_PROMPT}}}"
        SEMANTIC_MODE="${VITRIOL_SEMANTIC_MODE:-${CLI_SEMANTIC_MODE:-${CFG_SEMANTIC_MODE}}}"
        KV_QUANT="${CLI_KV_QUANT:-${CFG_KV_QUANT}}"
        LOOKUP="${CLI_LOOKUP:-${CFG_LOOKUP}}"
        ENGINE_MODE="${CLI_ENGINE_MODE:-${CLI_ENGINE_MODE:-${CFG_ENGINE_MODE}}}"
        KV_QUANT_V="${CLI_KV_QUANT_V:-${CFG_KV_QUANT_V}}"
DISK_OFFLOAD="${CLI_DISK_OFFLOAD:-0}"
        SPEC_TYPE="${CLI_SPEC_TYPE:-${CFG_SPEC_TYPE}}"
        SPEC_DRAFT_N_MAX="${CLI_SPEC_DRAFT_N_MAX:-${CFG_SPEC_DRAFT_N_MAX}}"
        EXPERT_COUNT="${CFG_EXPERT_COUNT}"
        OUTPUT_CACHE="${CFG_OUTPUT_CACHE}"
        REASONING="${CLI_REASONING:-${CFG_REASONING}}"
        PREDICTIVE_PREFETCH="${CFG_PREDICTIVE_PREFETCH}"
        PIN_FIRST_N_LAYERS="${CLI_PIN_LAYERS:-${CFG_PIN_FIRST_N_LAYERS}}"
        PRUNE_EXPERTS="${CLI_PRUNE_EXPERTS:-${CFG_PRUNE_EXPERTS}}"
        CHIMERA_MODE="${CLI_CHIMERA_MODE:-${CFG_CHIMERA_MODE}}"
        # Auto-disable output cache when pinning is active
        if [[ "${PIN_FIRST_N_LAYERS:-0}" -gt 0 ]] && [[ "$OUTPUT_CACHE" == "on" ]]; then
            OUTPUT_CACHE="off"
            echo "  → Output cache auto-disabled (pinning + output cache target different decode paths)"
        fi
        VERBOSE="${CLI_VERBOSE:-${CFG_VERBOSE}}"
        DEVICE="${CFG_DEVICE}"

        if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
            CUDA_DEVICES="${DEVICE}"
        else
            CUDA_DEVICES="0,1"
        fi

        # Pre-flight
        if [[ ! -f "$MODEL" ]]; then
            echo "ERROR: model not found: $MODEL"
            echo "  Set with: vitriol config (option 2)"
            echo "  Or:       vitriol run -m /path/to/model.gguf"
            exit 1
        fi
        if [[ ! -x "$BINARY" ]]; then
            echo "ERROR: binary not found: $BINARY"
            echo "  Build with: cd llama.cpp && cmake -B build -DGGML_CUDA=ON ... && cmake --build build -j\$(nproc)"
            exit 1
        fi

        CAPS=$(getcap "$BINARY" 2>/dev/null || true)
        if [[ "$CAPS" != *"cap_ipc_lock"* ]]; then
            echo "ERROR: CAP_IPC_LOCK not set on $BINARY"
            echo "  Run: vitriol setup"
            echo "  This is required for cudaHostRegister + mlock to work"
            exit 1
        fi

        MODEL_SIZE=$(stat --format=%s "$MODEL" 2>/dev/null | numfmt --to=iec || echo "?")

        MEMORY_MODE="${VITRIOL_MEMORY_MODE:-${CFG_MEMORY_MODE}}"
        SEMANTIC_MODE="${VITRIOL_SEMANTIC_MODE:-${CFG_SEMANTIC_MODE}}"

        # Print launch banner
        clear
        [[ -f "$HEADER_FILE" ]] && cat "$HEADER_FILE"
        echo ""
        mtp_flag=""
        model_has_mtp "$MODEL" && mtp_flag=" [MTP]"
        echo "═══ Launch Configuration ═══"
        echo "  Model:       $(basename "$MODEL") ($MODEL_SIZE)${mtp_flag}"
        echo "  Context:     $CTX tokens"
        echo "  Mode:        $MODE (RAM Shot + LRU cache)"
        [[ "$LRU_MB" -gt 0 ]] && echo "  LRU:         $LRU_MB MB VRAM cache"
        echo "  GPU:         Device $DEVICE (GTX 1070 Ti)"
        echo "  Memory:      $MEMORY_MODE"
        echo "  KV Mode:     $KV_MODE"
        echo "  Frozen:      $FROZEN_PROMPT"
        echo "  Semantic:    $SEMANTIC_MODE"
        echo "  K Quant:     $KV_QUANT"
        echo "  V Quant:     ${KV_QUANT_V:-f16}"
        echo "  Lookup:      $LOOKUP"
        echo "  Engine:      $ENGINE_MODE"
        [[ -n "$SPEC_TYPE" ]] && echo "  Spec Type:   $SPEC_TYPE"
        [[ "${SPEC_DRAFT_N_MAX:-0}" -gt 0 ]] && echo "  Draft N-Max: $SPEC_DRAFT_N_MAX"
        echo "  Chimera:     $CHIMERA_MODE"
        [[ "${PIN_FIRST_N_LAYERS:-0}" -gt 0 ]] && echo "  Pin Layers:  $PIN_FIRST_N_LAYERS (expert tensors in VRAM)"
        if [[ "${PRUNE_EXPERTS:-0}" -gt 0 ]]; then
            prune_keep=$((8 - PRUNE_EXPERTS))
            echo "  Expert Prune: $PRUNE_EXPERTS (keeping $prune_keep of 8)"
        fi
        [[ "${REASONING}" == "off" ]] && echo "  Reasoning:    off (Qwen3.6 mode)"
        echo "  Binary:      $BINARY"
        echo "  Port:        $PORT"
        [[ "$VERBOSE" == "true" ]] && echo "  Logging:     verbose"
        echo "═══════════════════════════════"
        echo ""

        if $DRY_RUN; then
            exit 0
        fi

        echo "Launching VITRIOL..."
        echo "  Model loading takes ~60s for 12 GB model"
        echo ""

        ENV_VERBOSE=""
        [[ "$VERBOSE" == "true" ]] && ENV_VERBOSE="VITRIOL_VERBOSE=1"
        ENV_PREDICTIVE_PREFETCH=""
        [[ "$PREDICTIVE_PREFETCH" == "on" ]] && ENV_PREDICTIVE_PREFETCH="VITRIOL_PREDICTIVE_PREFETCH=1"

        exec env \
            CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
            VITRIOL_MODE="$MODE" \
            VITRIOL_LRU_MB="$LRU_MB" \
            VITRIOL_MEMORY_MODE="$MEMORY_MODE" \
            VITRIOL_KV_MODE="$KV_MODE" \
            VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
            VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
            VITRIOL_KV_QUANT="$KV_QUANT" \
            VITRIOL_LOOKUP="$LOOKUP" \
            VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
            VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
            VITRIOL_EXPERT_COUNT="$EXPERT_COUNT" \
            VITRIOL_OUTPUT_CACHE="$OUTPUT_CACHE" \
            VITRIOL_PIN_FIRST_N_LAYERS="$PIN_FIRST_N_LAYERS" \
            VITRIOL_PRUNE_EXPERTS="$PRUNE_EXPERTS" \
            VITRIOL_EARLY_EXIT="${VITRIOL_EARLY_EXIT:-0}" \
            VITRIOL_EARLY_EXIT_THRESHOLD="${VITRIOL_EARLY_EXIT_THRESHOLD:-0.001}" \
            VITRIOL_EARLY_EXIT_MIN_LAYERS="${VITRIOL_EARLY_EXIT_MIN_LAYERS:-10}" \
            VITRIOL_MODEL_PATH="$MODEL" \
            VITRIOL_CHIMERA_MODE="$CHIMERA_MODE" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
            $ENV_VERBOSE \
            $ENV_PREDICTIVE_PREFETCH \
            "$BINARY" \
            -m "$MODEL" \
            -ngl "$NGL" \
            -c "$CTX" \
            -n 128 \
            -t "$THREADS" \
            "$@"
        ;;

    serve)
        shift
        CLI_MODEL=""
        CLI_CTX=""
        CLI_THREADS=""
        CLI_NGL=""
        CLI_LRU_MB=""
        CLI_PORT=""
        CLI_HOST=""
        CLI_PARALLEL=""
        CLI_VERBOSE=""
        CLI_MEMORY_MODE=""
        CLI_KV_MODE=""
        CLI_FROZEN_PROMPT=""
        CLI_SEMANTIC_MODE=""
        CLI_KV_QUANT=""
        CLI_LOOKUP=""
        CLI_ENGINE_MODE=""
        CLI_DISK_OFFLOAD=""
        CLI_SPEC_TYPE=""
        CLI_SPEC_DRAFT_N_MAX=""
        CLI_PIN_LAYERS=""
        CLI_PRUNE_EXPERTS=""
        CLI_REASONING=""
        DETACH=false
        DRY_RUN=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                -m) CLI_MODEL="$2"; shift 2 ;;
                -c) CLI_CTX="$2"; shift 2 ;;
                -t) CLI_THREADS="$2"; shift 2 ;;
                -ngl) CLI_NGL="$2"; shift 2 ;;
                -lru) CLI_LRU_MB="$2"; shift 2 ;;
                --host) CLI_HOST="$2"; shift 2 ;;
                -port) CLI_PORT="$2"; shift 2 ;;
                -p) CLI_PARALLEL="$2"; shift 2 ;;
                --memory-mode) CLI_MEMORY_MODE="$2"; shift 2 ;;
                --kv-mode) CLI_KV_MODE="$2"; shift 2 ;;
                --frozen-prompt) CLI_FROZEN_PROMPT="$2"; shift 2 ;;
                --semantic-mode) CLI_SEMANTIC_MODE="$2"; shift 2 ;;
                --kv-quant) CLI_KV_QUANT="$2"; shift 2 ;;
                --lookup) CLI_LOOKUP="$2"; shift 2 ;;
                --engine-mode) CLI_ENGINE_MODE="$2"; shift 2 ;;
                --spec-type) CLI_SPEC_TYPE="$2"; shift 2 ;;
                --spec-draft-n-max) CLI_SPEC_DRAFT_N_MAX="$2"; shift 2 ;;
                --disk-offload) CLI_DISK_OFFLOAD="1"; shift ;;
                --pin-layers) CLI_PIN_LAYERS="$2"; shift 2 ;;
                --prune-experts) CLI_PRUNE_EXPERTS="$2"; shift 2 ;;
                --reasoning) CLI_REASONING="$2"; shift 2 ;;
                --detach) DETACH=true; shift ;;
                --verbose) CLI_VERBOSE="true"; shift ;;
                --dry-run) DRY_RUN=true; shift;;
                -h|--help) usage; exit 0 ;;
                *) echo "Unknown: $1"; usage; exit 1 ;;
            esac
        done

        MODEL="${VITRIOL_MODEL:-${CLI_MODEL:-${CFG_MODEL}}}"
        CTX="${CLI_CTX:-${CFG_CTX}}"
        THREADS="${CLI_THREADS:-${CFG_THREADS}}"
        NGL="${CLI_NGL:-${CFG_NGL}}"
        LRU_MB="${CLI_LRU_MB:-${CFG_LRU_MB}}"
        PORT="${CLI_PORT:-${CFG_PORT}}"
        HOST="${CLI_HOST:-${CFG_HOST}}"
        PARALLEL="${CLI_PARALLEL:-${CFG_PARALLEL}}"
        MODE="${VITRIOL_MODE:-${CFG_MODE}}"
        MEMORY_MODE="${VITRIOL_MEMORY_MODE:-${CLI_MEMORY_MODE:-${CFG_MEMORY_MODE}}}"
        KV_MODE="${VITRIOL_KV_MODE:-${CLI_KV_MODE:-${CFG_KV_MODE}}}"
        FROZEN_PROMPT="${VITRIOL_FROZEN_PROMPT:-${CLI_FROZEN_PROMPT:-${CFG_FROZEN_PROMPT}}}"
        SEMANTIC_MODE="${VITRIOL_SEMANTIC_MODE:-${CLI_SEMANTIC_MODE:-${CFG_SEMANTIC_MODE}}}"
        KV_QUANT="${CLI_KV_QUANT:-${CFG_KV_QUANT}}"
        LOOKUP="${CLI_LOOKUP:-${CFG_LOOKUP}}"
        ENGINE_MODE="${CLI_ENGINE_MODE:-${CLI_ENGINE_MODE:-${CFG_ENGINE_MODE}}}"
        KV_QUANT_V="${CLI_KV_QUANT_V:-${CFG_KV_QUANT_V}}"
        DISK_OFFLOAD="${CLI_DISK_OFFLOAD:-0}"
        SPEC_TYPE="${CLI_SPEC_TYPE:-${CFG_SPEC_TYPE}}"
        SPEC_DRAFT_N_MAX="${CLI_SPEC_DRAFT_N_MAX:-${CFG_SPEC_DRAFT_N_MAX}}"
        EXPERT_COUNT="${CFG_EXPERT_COUNT}"
        OUTPUT_CACHE="${CFG_OUTPUT_CACHE}"
        REASONING="${CFG_REASONING}"
        PREDICTIVE_PREFETCH="${CFG_PREDICTIVE_PREFETCH}"
        PIN_FIRST_N_LAYERS="${CLI_PIN_LAYERS:-${CFG_PIN_FIRST_N_LAYERS}}"
        PRUNE_EXPERTS="${CLI_PRUNE_EXPERTS:-${CFG_PRUNE_EXPERTS}}"
        # Auto-disable output cache when pinning is active
        if [[ "${PIN_FIRST_N_LAYERS:-0}" -gt 0 ]] && [[ "$OUTPUT_CACHE" == "on" ]]; then
            OUTPUT_CACHE="off"
            echo "  → Output cache auto-disabled (pinning + output cache target different decode paths)"
        fi
        VERBOSE="${CLI_VERBOSE:-${CFG_VERBOSE}}"
        DEVICE="${CFG_DEVICE}"

        if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
            CUDA_DEVICES="${DEVICE}"
        else
            CUDA_DEVICES="0,1"
        fi

        if [[ ! -f "$MODEL" ]]; then
            echo "ERROR: model not found: $MODEL"
            echo "  Set with: vitriol config (option 2)"
            exit 1
        fi
        if [[ ! -x "$SERVER_BINARY" ]]; then
            echo "ERROR: server binary not found: $SERVER_BINARY"
            echo "  Build with: cd llama.cpp && cmake -B build -DGGML_CUDA=ON ... && cmake --build build -j\$(nproc)"
            exit 1
        fi

        # Check caps for server binary too
        SERVER_CAPS=$(getcap "$SERVER_BINARY" 2>/dev/null || true)
        if [[ "$SERVER_CAPS" != *"cap_ipc_lock"* ]]; then
            echo "ERROR: CAP_IPC_LOCK not set on $SERVER_BINARY"
            echo "  Run: vitriol setup"
            echo "  This is required for cudaHostRegister + mlock to work"
            exit 1
        fi

        MODEL_SIZE=$(stat --format=%s "$MODEL" 2>/dev/null | numfmt --to=iec || echo "?")

        clear
        [[ -f "$HEADER_FILE" ]] && cat "$HEADER_FILE"
        echo ""
        mtp_flag=""
        model_has_mtp "$MODEL" && mtp_flag=" [MTP]"
        echo "═══ VITRIOL Server ═══"
        echo "  Model:       $(basename "$MODEL") ($MODEL_SIZE)${mtp_flag}"
        echo "  Context:     $CTX tokens"
        echo "  Mode:        $MODE (RAM Shot + LRU cache)"
        [[ "$LRU_MB" -gt 0 ]] && echo "  LRU:         $LRU_MB MB VRAM cache"
        echo "  GPU:         Device $DEVICE (GTX 1070 Ti)"
        echo "  Memory:      $MEMORY_MODE"
        echo "  KV Mode:     $KV_MODE"
        echo "  Frozen:      $FROZEN_PROMPT"
        echo "  Semantic:    $SEMANTIC_MODE"
        echo "  K Quant:     $KV_QUANT"
        echo "  V Quant:     ${KV_QUANT_V:-f16}"
        echo "  Lookup:      $LOOKUP"
        echo "  Engine:      $ENGINE_MODE"
        [[ -n "$SPEC_TYPE" ]] && echo "  Spec Type:   $SPEC_TYPE"
        [[ "${SPEC_DRAFT_N_MAX:-0}" -gt 0 ]] && echo "  Draft N-Max: $SPEC_DRAFT_N_MAX"
        echo "  Chimera:     $CHIMERA_MODE"
        [[ "${PIN_FIRST_N_LAYERS:-0}" -gt 0 ]] && echo "  Pin Layers:  $PIN_FIRST_N_LAYERS (expert tensors in VRAM)"
        if [[ "${PRUNE_EXPERTS:-0}" -gt 0 ]]; then
            prune_keep=$((8 - PRUNE_EXPERTS))
            echo "  Expert Prune: $PRUNE_EXPERTS (keeping $prune_keep of 8)"
        fi
        [[ "${REASONING}" == "off" ]] && echo "  Reasoning:    off (Qwen3.6 mode)"
        if [[ "$MEMORY_MODE" == "on" ]]; then
            LLAMA_PORT=$((PORT - 1))
            echo "  Server:      http://${HOST}:${LLAMA_PORT} (llama-server, internal)"
            echo "  Proxy:       http://${HOST}:${PORT} (VITRIOL shim, memory intercept)"
        else
            echo "  Server:      http://${HOST}:${PORT}"
        fi
        echo "  Slots:     $PARALLEL parallel"
        [[ "$VERBOSE" == "true" ]] && echo "  Logging:   verbose"
        echo "═══════════════════════════"
        echo ""

        if $DRY_RUN; then
            exit 0
        fi

        ENV_VERBOSE=""
        [[ "$VERBOSE" == "true" ]] && ENV_VERBOSE="VITRIOL_VERBOSE=1"
        ENV_PREDICTIVE_PREFETCH=""
        [[ "$PREDICTIVE_PREFETCH" == "on" ]] && ENV_PREDICTIVE_PREFETCH="VITRIOL_PREDICTIVE_PREFETCH=1"

        # KV cache quant args (pass to llama-server as --cache-type-k and --cache-type-v)
        # NOTE: Setting --cache-type-v to q8_0 or q4_0 may produce garbage output with
        # VITRIOL expert offloading — leave V at f16 unless you've verified it works.
        KV_CACHE_ARGS=""
        [[ "$KV_QUANT" != "f16" ]] && KV_CACHE_ARGS="--cache-type-k $KV_QUANT"
        [[ "${KV_QUANT_V:-f16}" != "f16" ]] && KV_CACHE_ARGS="$KV_CACHE_ARGS --cache-type-v $KV_QUANT_V"
        # Speculative decoding args
        SPEC_ARGS=""
        [[ -n "$SPEC_TYPE" ]] && SPEC_ARGS="--spec-type $SPEC_TYPE"
        [[ "${SPEC_DRAFT_N_MAX:-0}" -gt 0 ]] && SPEC_ARGS="$SPEC_ARGS --spec-draft-n-max $SPEC_DRAFT_N_MAX"
        # Checkpoint interval: 4096 tokens for SSM rollback safety net (Approach A safety net)
        # Combined with Approach E (exact-boundary checkpoint at generation end),
        # fallback waste reduces from 4096 → ~2048 tokens worst case
        CKPT_ARGS="--checkpoint-every-n-tokens 4096"
        # Flash Attention is required for V cache quantization and generally faster
        FA_ARGS="-fa on"
        # Reasoning/thinking mode: off for Qwen3.6 models
        REASONING_ARGS=""
        [[ "${REASONING}" == "off" ]] && REASONING_ARGS="--reasoning off"

        if $DETACH; then
            echo "Starting server in background..."
            mkdir -p "$CONFIG_DIR"
            SHIM_DIR="$(dirname "$SCRIPT_DIR")/libvitriol"
            export LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

            if [[ "$MEMORY_MODE" == "on" ]]; then
                LLAMA_PORT=$((PORT - 1))
                # Start llama-server on internal port
                env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_EXPERT_COUNT="$EXPERT_COUNT" \
                    VITRIOL_OUTPUT_CACHE="$OUTPUT_CACHE" \
                    VITRIOL_PIN_FIRST_N_LAYERS="$PIN_FIRST_N_LAYERS" \
            VITRIOL_PRUNE_EXPERTS="$PRUNE_EXPERTS" \
            VITRIOL_EARLY_EXIT="${VITRIOL_EARLY_EXIT:-0}" \
            VITRIOL_EARLY_EXIT_THRESHOLD="${VITRIOL_EARLY_EXIT_THRESHOLD:-0.001}" \
            VITRIOL_EARLY_EXIT_MIN_LAYERS="${VITRIOL_EARLY_EXIT_MIN_LAYERS:-10}" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    $ENV_PREDICTIVE_PREFETCH \
                    nohup "$SERVER_BINARY" \
                        -m "$MODEL" \
                        -ngl "$NGL" \
                        -c "$CTX" \
                        --host "$HOST" \
                        --port "$LLAMA_PORT" \
                        --parallel "$PARALLEL" \
                        --no-mmap \
                         -t "$THREADS" \
                            $KV_CACHE_ARGS $FA_ARGS $SPEC_ARGS $REASONING_ARGS $CKPT_ARGS \
                            "$@" &>"${CONFIG_DIR}/llama-server.log" &
                echo $! > "${CONFIG_DIR}/llama-server.pid"
                echo "  llama-server PID: $! (internal port $LLAMA_PORT)"

                # Start Python shim on external port
                env \
                    VITRIOL_MEMORY_MODE=on \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    LLAMA_API_URL="http://${HOST}:${LLAMA_PORT}/v1/chat/completions" \
                    LLAMA_STATUS_URL="http://${HOST}:${LLAMA_PORT}/health" \
                    SHIM_PORT="$PORT" \
                    nohup python3 "$SHIM_DIR/vitriol_shim.py" \
                        &>"${CONFIG_DIR}/shim.log" &
                echo $! > "${CONFIG_DIR}/shim.pid"
                echo "  VITRIOL shim PID: $! (memory on port $PORT)"
            else
                # Start llama-server on external port directly
                env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_EXPERT_COUNT="$EXPERT_COUNT" \
                    VITRIOL_OUTPUT_CACHE="$OUTPUT_CACHE" \
                    VITRIOL_PIN_FIRST_N_LAYERS="$PIN_FIRST_N_LAYERS" \
            VITRIOL_PRUNE_EXPERTS="$PRUNE_EXPERTS" \
            VITRIOL_EARLY_EXIT="${VITRIOL_EARLY_EXIT:-0}" \
            VITRIOL_EARLY_EXIT_THRESHOLD="${VITRIOL_EARLY_EXIT_THRESHOLD:-0.001}" \
            VITRIOL_EARLY_EXIT_MIN_LAYERS="${VITRIOL_EARLY_EXIT_MIN_LAYERS:-10}" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    $ENV_PREDICTIVE_PREFETCH \
                    nohup "$SERVER_BINARY" \
                        -m "$MODEL" \
                        -ngl "$NGL" \
                        -c "$CTX" \
                        --host "$HOST" \
                        --port "$PORT" \
                        --parallel "$PARALLEL" \
                        --no-mmap \
                        -t "$THREADS" \
                        $KV_CACHE_ARGS $FA_ARGS $SPEC_ARGS $REASONING_ARGS $CKPT_ARGS \
                        "$@" &>"${CONFIG_DIR}/server.log" &
                echo $! > "${CONFIG_DIR}/server.pid"
                echo "  Server PID: $!"
            fi

            echo "  Log dir:   ${CONFIG_DIR}"
            echo ""
            echo "  curl http://${HOST}:${PORT}/v1/chat/completions \\"
            echo "    -H \"Content-Type: application/json\" \\"
            echo "    -H \"X-Project-Id: my_project\" \\"
            echo "    -H \"X-Session-Id: my_session\" \\"
            echo "    -d '{\"messages\":[{\"role\":\"user\",\"content\":\"Hello\"}],\"max_tokens\":50}'"
        else
            echo "Starting server (Ctrl+C to stop)..."
            echo ""
            export LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

            if [[ "$MEMORY_MODE" == "on" ]]; then
                LLAMA_PORT=$((PORT - 1))
                SHIM_DIR="$(dirname "$SCRIPT_DIR")/libvitriol"

                # Start llama-server in background on internal port
                env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_EXPERT_COUNT="$EXPERT_COUNT" \
                    VITRIOL_OUTPUT_CACHE="$OUTPUT_CACHE" \
                    VITRIOL_PIN_FIRST_N_LAYERS="$PIN_FIRST_N_LAYERS" \
            VITRIOL_PRUNE_EXPERTS="$PRUNE_EXPERTS" \
            VITRIOL_EARLY_EXIT="${VITRIOL_EARLY_EXIT:-0}" \
            VITRIOL_EARLY_EXIT_THRESHOLD="${VITRIOL_EARLY_EXIT_THRESHOLD:-0.001}" \
            VITRIOL_EARLY_EXIT_MIN_LAYERS="${VITRIOL_EARLY_EXIT_MIN_LAYERS:-10}" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    $ENV_PREDICTIVE_PREFETCH \
                    "$SERVER_BINARY" \
                        -m "$MODEL" \
                        -ngl "$NGL" \
                        -c "$CTX" \
                        --host "$HOST" \
                        --port "$LLAMA_PORT" \
                        --parallel "$PARALLEL" \
                        --no-mmap \
                        -t "$THREADS" $KV_CACHE_ARGS $FA_ARGS $SPEC_ARGS $REASONING_ARGS &
                LLAMA_PID=$!
                echo "  llama-server running (PID $LLAMA_PID, internal port $LLAMA_PORT)"

                # Trap Ctrl+C to clean up llama-server
                trap "echo 'Shutting down...'; kill $LLAMA_PID 2>/dev/null; exit 0" INT TERM

                # Start shim in foreground on external port
                echo "  Starting VITRIOL memory shim on port $PORT..."
                env \
                    VITRIOL_MEMORY_MODE=on \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    LLAMA_API_URL="http://${HOST}:${LLAMA_PORT}/v1/chat/completions" \
                    LLAMA_STATUS_URL="http://${HOST}:${LLAMA_PORT}/health" \
                    SHIM_PORT="$PORT" \
                    python3 "$SHIM_DIR/vitriol_shim.py"
            else
                exec env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_EXPERT_COUNT="$EXPERT_COUNT" \
                    VITRIOL_OUTPUT_CACHE="$OUTPUT_CACHE" \
                    VITRIOL_PIN_FIRST_N_LAYERS="$PIN_FIRST_N_LAYERS" \
            VITRIOL_PRUNE_EXPERTS="$PRUNE_EXPERTS" \
            VITRIOL_EARLY_EXIT="${VITRIOL_EARLY_EXIT:-0}" \
            VITRIOL_EARLY_EXIT_THRESHOLD="${VITRIOL_EARLY_EXIT_THRESHOLD:-0.001}" \
            VITRIOL_EARLY_EXIT_MIN_LAYERS="${VITRIOL_EARLY_EXIT_MIN_LAYERS:-10}" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    $ENV_PREDICTIVE_PREFETCH \
                    "$SERVER_BINARY" \
                    -m "$MODEL" \
                    -ngl "$NGL" \
                    -c "$CTX" \
                    --host "$HOST" \
                    --port "$PORT" \
                    --parallel "$PARALLEL" \
                    --no-mmap \
                    -t "$THREADS" \
                    $KV_CACHE_ARGS $FA_ARGS $SPEC_ARGS $REASONING_ARGS \
                    "$@"
            fi
        fi
        ;;

    stop)
        STOPPED=false

        # Stop shim (memory mode)
        SHIM_PID_FILE="${CONFIG_DIR}/shim.pid"
        if [[ -f "$SHIM_PID_FILE" ]]; then
            PID=$(cat "$SHIM_PID_FILE")
            echo "→ Stopping VITRIOL shim (PID $PID)..."
            kill "$PID" 2>/dev/null && echo "  ✓ Shim stopped" || echo "  (shim not running)"
            rm -f "$SHIM_PID_FILE"
            STOPPED=true
        fi

        # Stop llama-server (internal port in memory mode, or standard)
        LLAMA_PID_FILE="${CONFIG_DIR}/llama-server.pid"
        if [[ -f "$LLAMA_PID_FILE" ]]; then
            PID=$(cat "$LLAMA_PID_FILE")
            echo "→ Stopping llama-server (PID $PID)..."
            kill "$PID" 2>/dev/null && echo "  ✓ llama-server stopped" || echo "  (llama-server not running)"
            rm -f "$LLAMA_PID_FILE"
            STOPPED=true
        fi

        # Stop standard server
        PID_FILE="${CONFIG_DIR}/server.pid"
        if [[ -f "$PID_FILE" ]]; then
            PID=$(cat "$PID_FILE")
            echo "→ Stopping server (PID $PID)..."
            kill "$PID" 2>/dev/null && echo "  ✓ Stopped" || echo "  (not running)"
            rm -f "$PID_FILE"
            STOPPED=true
        fi

        if $STOPPED; then
            echo "  Waiting for graceful shutdown (DMA cleanup)..."
            sleep 2
        fi

        if ! $STOPPED; then
            echo "→ No PID files found. Searching for running processes..."
            pkill -f "llama-server.*Qwen3" 2>/dev/null && echo "  ✓ llama-server stopped" || true
            pkill -f "vitriol_shim" 2>/dev/null && echo "  ✓ VITRIOL shim stopped" || true
        fi
        ;;

    bench)
        shift
        # Run a quick benchmark using llama-bench
        CLI_MODEL=""
        CLI_CTX=""
        CLI_NGL=""
        CLI_LRU_MB=""
        CLI_VERBOSE=""
        CLI_PIN_LAYERS=""
        CLI_PRUNE_EXPERTS=""
        CLI_N=100
        DRY_RUN=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                -m) CLI_MODEL="$2"; shift 2 ;;
                -c) CLI_CTX="$2"; shift 2 ;;
                -ngl) CLI_NGL="$2"; shift 2 ;;
                -lru) CLI_LRU_MB="$2"; shift 2 ;;
                -n) CLI_N="$2"; shift 2 ;;
                --pin-layers) CLI_PIN_LAYERS="$2"; shift 2 ;;
                --prune-experts) CLI_PRUNE_EXPERTS="$2"; shift 2 ;;
                --verbose) CLI_VERBOSE="true"; shift ;;
                --dry-run) DRY_RUN=true; shift ;;
                -h|--help) usage; exit 0 ;;
                *) echo "Unknown: $1"; usage; exit 1 ;;
            esac
        done

        MODEL="${VITRIOL_MODEL:-${CLI_MODEL:-${CFG_MODEL}}}"
        CTX="${CLI_CTX:-${CFG_CTX}}"
        NGL="${CLI_NGL:-${CFG_NGL}}"
        LRU_MB="${CLI_LRU_MB:-${CFG_LRU_MB}}"
        MODE="${VITRIOL_MODE:-${CFG_MODE}}"
        OUTPUT_CACHE="${CFG_OUTPUT_CACHE}"
        PREDICTIVE_PREFETCH="${CFG_PREDICTIVE_PREFETCH}"
        PIN_FIRST_N_LAYERS="${CLI_PIN_LAYERS:-${CFG_PIN_FIRST_N_LAYERS}}"
        PRUNE_EXPERTS="${CLI_PRUNE_EXPERTS:-${CFG_PRUNE_EXPERTS}}"
        VERBOSE="${CLI_VERBOSE:-${CFG_VERBOSE}}"
        DEVICE="${CFG_DEVICE}"

        N="${CLI_N}"

        if [[ "${PIN_FIRST_N_LAYERS:-0}" -gt 0 ]] && [[ "$OUTPUT_CACHE" == "on" ]]; then
            OUTPUT_CACHE="off"
        fi

        if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
            CUDA_DEVICES="${DEVICE}"
        else
            CUDA_DEVICES="0,1"
        fi

        BENCH_BINARY="${LLAMA_DIR}/build/bin/llama-bench"

        if [[ ! -f "$MODEL" ]]; then
            echo "ERROR: model not found: $MODEL"; exit 1
        fi
        if [[ ! -x "$BENCH_BINARY" ]]; then
            echo "ERROR: llama-bench not found at $BENCH_BINARY"; exit 1
        fi

        MODEL_SIZE=$(stat --format=%s "$MODEL" 2>/dev/null | numfmt --to=iec || echo "?")

        echo "═══ VITRIOL Bench ═══"
        echo "  Model:    $(basename "$MODEL") ($MODEL_SIZE)"
        echo "  Gen:      $N tokens"
        echo "  GPU:      Device $DEVICE"
        echo "  Mode:     $MODE"
        [[ "$OUTPUT_CACHE" == "on" ]] && echo "  Cache:    output cache"
        [[ "$PREDICTIVE_PREFETCH" == "on" ]] && echo "  Prefetch: predictive"
        [[ "${PIN_FIRST_N_LAYERS:-0}" -gt 0 ]] && echo "  Pin:      $PIN_FIRST_N_LAYERS layers"
        [[ "${PRUNE_EXPERTS:-0}" -gt 0 ]] && echo "  Prune:    $PRUNE_EXPERTS experts"
        [[ "${NGL}" -gt 0 ]] && echo "  NGL:      $NGL"
        echo "══════════════════════"
        echo ""

        if $DRY_RUN; then
            exit 0
        fi

        ENV_VERBOSE=""
        [[ "$VERBOSE" == "true" ]] && ENV_VERBOSE="VITRIOL_VERBOSE=1"
        ENV_PREDICTIVE_PREFETCH=""
        [[ "$PREDICTIVE_PREFETCH" == "on" ]] && ENV_PREDICTIVE_PREFETCH="VITRIOL_PREDICTIVE_PREFETCH=1"

        echo "NOTE: Run 'vitriol setup' first for CAP_IPC_LOCK on llama-bench"
        echo ""

        env \
            CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
            VITRIOL_MODE="$MODE" \
            VITRIOL_LRU_MB="$LRU_MB" \
            VITRIOL_OUTPUT_CACHE="$OUTPUT_CACHE" \
            VITRIOL_PIN_FIRST_N_LAYERS="$PIN_FIRST_N_LAYERS" \
            VITRIOL_PRUNE_EXPERTS="$PRUNE_EXPERTS" \
            VITRIOL_EARLY_EXIT="${VITRIOL_EARLY_EXIT:-0}" \
            VITRIOL_EARLY_EXIT_THRESHOLD="${VITRIOL_EARLY_EXIT_THRESHOLD:-0.001}" \
            VITRIOL_EARLY_EXIT_MIN_LAYERS="${VITRIOL_EARLY_EXIT_MIN_LAYERS:-10}" \
            VITRIOL_PREDICTIVE_PREFETCH="$PREDICTIVE_PREFETCH" \
            LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
            $ENV_VERBOSE \
            "$BENCH_BINARY" \
            -m "$MODEL" \
            -ngl "$NGL" \
            -c "${CTX}" \
            -p 64 \
            -n "$N" \
            -t 4 2>&1
        ;;

    tui)
        TUI_SCRIPT="${LLAMA_DIR}/../libvitriol/vitriol-tui.py"
        if [[ ! -f "$TUI_SCRIPT" ]]; then
            echo "ERROR: TUI script not found at $TUI_SCRIPT"
            exit 1
        fi
        # Check if textual is installed
        python3 -c "import textual" 2>/dev/null || {
            echo "ERROR: Textual Python library not installed"
            echo "  Install with: pip install --user textual"
            exit 1
        }
        echo "Starting VITRIOL TUI Dashboard..."
        echo "  (Run 'vitriol serve --detach' first to have stats)"
        echo ""
        python3 "$TUI_SCRIPT" "${@}"
        ;;

    config)
        shift
        case "${1:-}" in
            show)  config_show ;;
            init)  config_init ;;
            reset) config_reset ;;
            edit)  ${EDITOR:-vim} "$CONFIG_FILE" ;;
            set)   shift; config_set "$1" "$2" ;;
            *)     tui_main_menu ;;
        esac
        ;;

    setup)
        setup_caps "$BINARY"
        if [[ -x "$SERVER_BINARY" ]]; then
            setup_caps "$SERVER_BINARY"
        fi
        # Also set caps on llama-bench if it exists
        BENCH_BINARY="${LLAMA_DIR}/build/bin/llama-bench"
        if [[ -x "$BENCH_BINARY" ]]; then
            setup_caps "$BENCH_BINARY"
        fi
        ;;

    help|--help|-h)
        usage
        ;;

    *)
        usage
        exit 1
        ;;
esac
