#!/bin/bash
# VITRIOL — MoE Expert Offloading via PCIe DMA
#
# Usage:
#   vitriol run              launch inference
#   vitriol config           interactive config TUI
#   vitriol setup            set CAP_IPC_LOCK capability
#   vitriol help             this message

set -euo pipefail

# ── paths ────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LLAMA_DIR="${PROJECT_DIR}/llama.cpp"
BINARY="${LLAMA_DIR}/build/bin/llama-cli"
SERVER_BINARY="${LLAMA_DIR}/build/bin/llama-server"
HEADER_FILE="${PROJECT_DIR}/assets/vitriol-header.txt"
CONFIG_DIR="${HOME}/.vitriol"
CONFIG_FILE="${CONFIG_DIR}/config"

# ── defaults ─────────────────────────────────────────────────────
DEFAULT_MODEL="/mnt/data/ai/koboldcpp/Qwen3.6-35B-A3B-UD-Q2_K_XL.gguf"
DEFAULT_CTX=4096
DEFAULT_THREADS=4
DEFAULT_NGL=99
DEFAULT_PORT=8279
DEFAULT_HOST="0.0.0.0"
DEFAULT_PARALLEL=4
DEFAULT_MODE="stream"
DEFAULT_LRU_MB=512
DEFAULT_DEVICE=0
DEFAULT_EXCLUDE_SECONDARY=true
DEFAULT_VERBOSE=false
DEFAULT_MEMORY_MODE="off"
DEFAULT_KV_MODE="standard"
DEFAULT_FROZEN_PROMPT="off"
DEFAULT_SEMANTIC_MODE="off"
DEFAULT_KV_QUANT="f16"
DEFAULT_LOOKUP=0
DEFAULT_ENGINE_MODE="vitriol-dma"

# ── config vars (set by parse_config) ────────────────────────────
CFG_DEVICE="$DEFAULT_DEVICE"
CFG_EXCLUDE_SECONDARY="$DEFAULT_EXCLUDE_SECONDARY"
CFG_MODEL="$DEFAULT_MODEL"
CFG_CTX="$DEFAULT_CTX"
CFG_THREADS="$DEFAULT_THREADS"
CFG_NGL="$DEFAULT_NGL"
CFG_MODE="$DEFAULT_MODE"
CFG_LRU_MB="$DEFAULT_LRU_MB"
CFG_VERBOSE="$DEFAULT_VERBOSE"
CFG_PORT="$DEFAULT_PORT"
CFG_HOST="$DEFAULT_HOST"
CFG_PARALLEL="$DEFAULT_PARALLEL"
CFG_MEMORY_MODE="$DEFAULT_MEMORY_MODE"
CFG_KV_MODE="$DEFAULT_KV_MODE"
CFG_FROZEN_PROMPT="$DEFAULT_FROZEN_PROMPT"
CFG_SEMANTIC_MODE="$DEFAULT_SEMANTIC_MODE"
CFG_KV_QUANT="$DEFAULT_KV_QUANT"
CFG_LOOKUP="$DEFAULT_LOOKUP"
CFG_ENGINE_MODE="$DEFAULT_ENGINE_MODE"

# ═════════════════════════════════════════════════════════════════
# CONFIG PARSING
# ═════════════════════════════════════════════════════════════════

parse_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        return 0
    fi
    local section=""
    while IFS= read -r line; do
        line="${line%%#*}"        # strip comments
        line="${line##*( )}"      # strip leading space (shopt extglob may not be on)
        line="${line%%*( )}"      # strip trailing space
        [[ -z "$line" ]] && continue
        if [[ "$line" =~ ^\[([^\]]+)\]$ ]]; then
            section="${BASH_REMATCH[1]}"
            continue
        fi
        if [[ "$line" =~ ^([a-zA-Z_]+)[[:space:]]*=[[:space:]]*(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local val="${BASH_REMATCH[2]}"
            # strip quotes
            val="${val#\"}"; val="${val%\"}"
            val="${val#\'}"; val="${val%\'}"
            case "${section}.${key}" in
                gpu.device)            CFG_DEVICE="$val" ;;
                gpu.exclude_secondary) CFG_EXCLUDE_SECONDARY="$val" ;;
                model.path)            CFG_MODEL="$val" ;;
                model.context)         CFG_CTX="$val" ;;
                model.threads)         CFG_THREADS="$val" ;;
                model.ngl)             CFG_NGL="$val" ;;
                vitriol.mode)          CFG_MODE="$val" ;;
                vitriol.lru_mb)        CFG_LRU_MB="$val" ;;
                vitriol.verbose)       CFG_VERBOSE="$val" ;;
                server.host)           CFG_HOST="$val" ;;
                server.parallel)       CFG_PARALLEL="$val" ;;
                server.port)           CFG_PORT="$val" ;;
                memory.mode)           CFG_MEMORY_MODE="$val" ;;
                memory.semantic_mode)  CFG_SEMANTIC_MODE="$val" ;;
                kv.mode)               CFG_KV_MODE="$val" ;;
                kv.frozen_prompt)      CFG_FROZEN_PROMPT="$val" ;;
                kv.quant_mode)         CFG_KV_QUANT="$val" ;;
                lookup_tokens)         CFG_LOOKUP="$val" ;;
                engine.mode)             CFG_ENGINE_MODE="$val" ;;
            esac
        fi
    done < "$CONFIG_FILE"
}

write_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<CFGEOF
# VITRIOL Configuration
# Generated by vitriol config
# Uncomment and edit, or use: vitriol config

[gpu]
# CUDA device index to use
device = $CFG_DEVICE
# Exclude secondary GPU (GTX 960, CC 5.2 lacks kernel images)
exclude_secondary = $CFG_EXCLUDE_SECONDARY

[model]
# Path to GGUF model file
path = $CFG_MODEL
# Context window size
context = $CFG_CTX
# CPU threads for prompt processing
threads = $CFG_THREADS
# GPU layers to offload
ngl = $CFG_NGL

[vitriol]
# Operation mode: stream | sync | async | off
mode = $CFG_MODE
# LRU VRAM cache in MB (0 to disable)
lru_mb = $CFG_LRU_MB
# Verbose logging
verbose = $CFG_VERBOSE

[server]
# API host address
host = $CFG_HOST
# API port
port = $CFG_PORT
# Parallel slots for concurrent requests
parallel = $CFG_PARALLEL

[memory]
# Emulated memory mode: on | off
mode = $CFG_MEMORY_MODE
# Semantic search mode: on | off (requires sentence-transformers)
semantic_mode = $CFG_SEMANTIC_MODE

[kv]
# KV cache mode: standard | offload | sparse
mode = $CFG_KV_MODE

# Frozen prompt: on | off (keep system prompt static to avoid re-prefix)
frozen_prompt = $CFG_FROZEN_PROMPT

[engine]
# Execution mode: vitriol-dma | native
mode = $CFG_ENGINE_MODE

[lookup]
# Prompt lookup decoding tokens (0 = disabled)
tokens = $CFG_LOOKUP
CFGEOF
}

config_init() {
    write_config
    echo "✓ Config written to $CONFIG_FILE"
}

config_show() {
    local box_w=44
    local inner=$((box_w - 4))
    local line
    print_row() {
        local label="$1" val="$2"
        local display="${val}"
        if [[ ${#display} -gt $inner ]]; then
            display="${display:0:$((inner-3))}..."
        fi
        printf "║  %-*s ║\n" "$inner" "${label}${display}"
    }

    echo "╔$(printf '═%.0s' $(seq 1 $box_w))╗"
    printf "║  %-*s ║\n" "$inner" "VITRIOL Configuration"
    echo "╠$(printf '═%.0s' $(seq 1 $box_w))╣"
    print_row "GPU Device:            " "${CFG_DEVICE}"
    print_row "Exclude Secondary:     " "${CFG_EXCLUDE_SECONDARY}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Model:                 " "$(basename "${CFG_MODEL}" 2>/dev/null || echo "?")"
    print_row "Path:                  " "${CFG_MODEL}"
    print_row "Context:               " "${CFG_CTX}"
    print_row "Threads:               " "${CFG_THREADS}"
    print_row "GPU Layers (ngl):      " "${CFG_NGL}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "VITRIOL Mode:          " "${CFG_MODE}"
    print_row "LRU Cache (MB):        " "${CFG_LRU_MB}"
    print_row "Verbose:               " "${CFG_VERBOSE}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Memory Mode:           " "${CFG_MEMORY_MODE}"
    print_row "  Semantic Search:     " "${CFG_SEMANTIC_MODE}"
    print_row "KV Mode:               " "${CFG_KV_MODE}"
    print_row "Frozen Prompt:         " "${CFG_FROZEN_PROMPT}"
    print_row "KV Quant:              " "${CFG_KV_QUANT}"
    print_row "Prompt Lookup:         " "${CFG_LOOKUP}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Engine Mode:           " "${CFG_ENGINE_MODE}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Server Host:           " "${CFG_HOST}"
    print_row "Server Port:           " "${CFG_PORT}"
    print_row "Parallel Slots:        " "${CFG_PARALLEL}"
    echo "╚$(printf '═%.0s' $(seq 1 $box_w))╝"
}

config_reset() {
    CFG_DEVICE="$DEFAULT_DEVICE"
    CFG_EXCLUDE_SECONDARY="$DEFAULT_EXCLUDE_SECONDARY"
    CFG_MODEL="$DEFAULT_MODEL"
    CFG_CTX="$DEFAULT_CTX"
    CFG_THREADS="$DEFAULT_THREADS"
    CFG_NGL="$DEFAULT_NGL"
    CFG_MODE="$DEFAULT_MODE"
    CFG_LRU_MB="$DEFAULT_LRU_MB"
    CFG_VERBOSE="$DEFAULT_VERBOSE"
    CFG_PORT="$DEFAULT_PORT"
    CFG_HOST="$DEFAULT_HOST"
    CFG_PARALLEL="$DEFAULT_PARALLEL"
    write_config
    echo "✓ Config reset to defaults"
}

config_set() {
    local key="$1" val="$2"
    case "$key" in
        gpu.device)            CFG_DEVICE="$val" ;;
        gpu.exclude_secondary) CFG_EXCLUDE_SECONDARY="$val" ;;
        model.path)            CFG_MODEL="$val" ;;
        model.context)         CFG_CTX="$val" ;;
        model.threads)         CFG_THREADS="$val" ;;
        model.ngl)             CFG_NGL="$val" ;;
        vitriol.mode)          CFG_MODE="$val" ;;
        vitriol.lru_mb)        CFG_LRU_MB="$val" ;;
        vitriol.verbose)       CFG_VERBOSE="$val" ;;
        server.host)           CFG_HOST="$val" ;;
        server.parallel)       CFG_PARALLEL="$val" ;;
        server.port)           CFG_PORT="$val" ;;
        memory.mode)           CFG_MEMORY_MODE="$val" ;;
        memory.semantic_mode)  CFG_SEMANTIC_MODE="$val" ;;
        kv.mode)               CFG_KV_MODE="$val" ;;
        kv.quant_mode)         CFG_KV_QUANT="$val" ;;
        lookup_tokens)          CFG_LOOKUP="$val" ;;
        engine.mode)           CFG_ENGINE_MODE="$val" ;;
        frozen_prompt)         CFG_FROZEN_PROMPT="$val" ;;
        *) echo "Unknown key: $key"; return 1 ;;
    esac
    write_config
    echo "✓ $key = $val"
}

# ═════════════════════════════════════════════════════════════════
# HEADER
# ═════════════════════════════════════════════════════════════════

print_header() {
    if [[ -f "$HEADER_FILE" ]]; then
        cat "$HEADER_FILE"
    else
        echo "VITRIOL — MoE Expert Offloading"
    fi
    echo ""
}

# ═════════════════════════════════════════════════════════════════
# TUI MENU
# ═════════════════════════════════════════════════════════════════

tui_main_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║           Configuration Menu             ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) GPU Settings"
        printf "║  %-37s ║\n" "2) Model Settings"
        printf "║  %-37s ║\n" "3) VITRIOL Mode"
        printf "║  %-37s ║\n" "4) Memory Settings"
        printf "║  %-37s ║\n" "5) Engine Settings"
        printf "║  %-37s ║\n" "6) Server Settings"
        printf "║  %-37s ║\n" "7) Show Current Config"
        printf "║  %-37s ║\n" "8) Reset to Defaults"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-9/q]: " choice
        case "$choice" in
            1) tui_gpu_menu ;;
            2) tui_model_menu ;;
            3) tui_vitriol_menu ;;
            4) tui_memory_menu ;;
            5) tui_engine_menu ;;
            6) tui_server_menu ;;
            7) clear; print_header; config_show; echo ""; read -r -p "Press Enter to continue..." ;;
            8) config_reset; echo ""; read -r -p "Press Enter to continue..." ;;
            q|Q) clear; exit 0 ;;
            *) ;;
        esac
    done
}

tui_gpu_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║            GPU Settings                  ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Device Index     [${CFG_DEVICE}]"
        printf "║  %-37s ║\n" "2) Exclude Secondary [${CFG_EXCLUDE_SECONDARY}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-2/b/q]: " choice
        case "$choice" in
            1)
                read -r -p "Enter device index (0-7): " val
                if [[ "$val" =~ ^[0-7]$ ]]; then
                    config_set gpu.device "$val"
                else
                    echo "Invalid (must be 0-7)"; sleep 1
                fi
                ;;
            2)
                if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
                    config_set gpu.exclude_secondary "false"
                else
                    config_set gpu.exclude_secondary "true"
                fi
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_model_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Model Settings                  ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Model Path       [$(basename "${CFG_MODEL}" 2>/dev/null || echo "?" )]"
        printf "║  %-37s ║\n" "2) Context Window   [${CFG_CTX}]"
        printf "║  %-37s ║\n" "3) Threads          [${CFG_THREADS}]"
        printf "║  %-37s ║\n" "4) GPU Layers (ngl) [${CFG_NGL}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                echo "Enter new model path (Tab completion available):"
                read -r -e -p "> " val
                val="${val/#\~/$HOME}"
                if [[ -n "$val" ]]; then
                    config_set model.path "$val"
                fi
                ;;
            2)
                read -r -p "Enter context window (512-1000000): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 512 && val <= 1000000)); then
                    config_set model.context "$val"
                else
                    echo "Invalid (must be 512-1000000)"; sleep 1
                fi
                ;;
            3)
                read -r -p "Enter threads (1-32): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 32)); then
                    config_set model.threads "$val"
                else
                    echo "Invalid (must be 1-32)"; sleep 1
                fi
                ;;
            4)
                read -r -p "Enter GPU layers/ngl (1-99): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 99)); then
                    config_set model.ngl "$val"
                else
                    echo "Invalid (must be 1-99)"; sleep 1
                fi
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_vitriol_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          VITRIOL Mode Settings           ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Operation Mode   [${CFG_MODE}]"
        printf "║  %-37s ║\n" "2) LRU Cache (MB)   [${CFG_LRU_MB}]"
        printf "║  %-37s ║\n" "3) Verbose Logging  [${CFG_VERBOSE}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                echo "Modes: stream (RAM Shot + LRU) | sync | async | off"
                read -r -p "Enter mode: " val
                case "$val" in
                    stream|sync|async|off) config_set vitriol.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            2)
                read -r -p "Enter LRU cache MB (0-4096, 0=off): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 4096)); then
                    config_set vitriol.lru_mb "$val"
                else
                    echo "Invalid (must be 0-4096)"; sleep 1
                fi
                ;;
            3)
                if [[ "$CFG_VERBOSE" == "true" ]]; then
                    config_set vitriol.verbose "false"
                else
                    config_set vitriol.verbose "true"
                fi
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_memory_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Context & Memory Settings       ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Memory Mode      [${CFG_MEMORY_MODE}]"
        printf "║  %-37s ║\n" "2) KV Mode           [${CFG_KV_MODE}]"
        printf "║  %-37s ║\n" "3) Frozen Prompt     [${CFG_FROZEN_PROMPT}]"
        printf "║  %-37s ║\n" "4) Semantic Search   [${CFG_SEMANTIC_MODE}]"
        printf "║  %-37s ║\n" "5) KV Quant          [${CFG_KV_QUANT}]"
        printf "║  %-37s ║\n" "6) Prompt Lookup     [${CFG_LOOKUP}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                echo "Modes: on (emulated memory) | off (direct)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set memory.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            2)
                echo "Modes: standard (default) | offload (system RAM) | sparse (attention eviction)"
                read -r -p "Enter mode: " val
                case "$val" in
                    standard|offload|sparse) config_set kv.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            3)
                echo "Options: on (keep system prompt frozen) | off (default)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set frozen_prompt "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            4)
                echo "Options: on (semantic search via sentence-transformers) | off (keyword search)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set memory.semantic_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_engine_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Engine Settings                  ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Engine Mode      [${CFG_ENGINE_MODE}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1/b/q]: " choice
        case "$choice" in
            1)
                echo "Modes: vitriol-dma (RAM Shot + LRU, default) | native (standard llama.cpp)"
                read -r -p "Enter mode: " val
                case "$val" in
                    vitriol-dma|native) config_set engine.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}


tui_server_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Server Settings                 ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Host Address     [${CFG_HOST}]"
        printf "║  %-37s ║\n" "2) Port Number      [${CFG_PORT}]"
        printf "║  %-37s ║\n" "3) Parallel Slots   [${CFG_PARALLEL}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                read -r -p "Enter host address: " val
                if [[ -n "$val" ]]; then
                    config_set server.host "$val"
                fi
                ;;
            2)
                read -r -p "Enter port (1024-65535): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1024 && val <= 65535)); then
                    config_set server.port "$val"
                else
                    echo "Invalid (must be 1024-65535)"; sleep 1
                fi
                ;;
            3)
                read -r -p "Enter parallel slots (1-8): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 8)); then
                    config_set server.parallel "$val"
                else
                    echo "Invalid (must be 1-8)"; sleep 1
                fi
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

# ═════════════════════════════════════════════════════════════════
# RUN & SERVE
# ═════════════════════════════════════════════════════════════════

setup_caps() {
    local bin="${1:-$BINARY}"
    echo "→ Setting CAP_IPC_LOCK on $bin"
    if ! command -v sudo &>/dev/null; then
        echo "  ERROR: sudo not found"
        exit 1
    fi
    sudo setcap cap_ipc_lock=+ep "$bin"
    echo "  ✓ Done"
    getcap "$bin"
    echo ""
    echo "System RAM for page-locking: $(free -g | awk '/^Mem:/{print $2}') GiB total"
    echo "                             $(free -g | awk '/^Mem:/{print int($2*0.8)}') GiB available without swap pressure"
}

usage() {
    print_header
    cat <<'HEREDOC'
  vitriol run [options]      interactive inference session
  vitriol serve [options]    persistent HTTP API server
  vitriol stop               stop running server
  vitriol config             interactive configuration TUI
  vitriol config show        print current configuration
  vitriol config init        create config file with defaults
  vitriol config reset       restore defaults
  vitriol config edit        open config in $EDITOR
  vitriol config set <key> <val>  set a config value
  vitriol setup              set CAP_IPC_LOCK capability
  vitriol help               this message

Run options:
  -m PATH            model file path
  -c N               context window (tokens)
  -t N               CPU threads
  -ngl N             GPU layers to offload
  -lru MB            LRU VRAM cache size
  --memory-mode MODE   emulated memory: on | off
  --kv-mode MODE       KV cache: standard | offload | sparse
  --frozen-prompt M    frozen prompt caching: on | off
  --semantic-mode M    semantic search: on | off (requires sentence-transformers)
  --verbose            enable debug logging
  --dry-run            print config without launching

Serve options:
  -m PATH            model file path
  -c N               context window (tokens)
  -t N               CPU threads
  -ngl N             GPU layers to offload
  -lru MB            LRU VRAM cache size
  --host ADDR        bind address (default: $DEFAULT_HOST)
  -port N            server port (default: $DEFAULT_PORT)
  -p N               parallel slots (default: $DEFAULT_PARALLEL)
  --memory-mode MODE   emulated memory: on | off
  --kv-mode MODE       KV cache: standard | offload | sparse
  --frozen-prompt M    frozen prompt caching: on | off
  --semantic-mode M    semantic search: on | off (requires sentence-transformers)
  --detach             run server in background
  --verbose          enable debug logging
  --dry-run          print config without launching

All options can be persisted via: vitriol config

HEREDOC
}

# ═════════════════════════════════════════════════════════════════
# MAIN
# ═════════════════════════════════════════════════════════════════

# Parse config before command dispatch so env vars override
parse_config

CMD="${1:-help}"
case "$CMD" in
    run)
        shift
        # CLI flags override config
        CLI_MODEL=""
        CLI_CTX=""
        CLI_THREADS=""
        CLI_NGL=""
        CLI_PORT=""
        CLI_LRU_MB=""
        CLI_VERBOSE=""
        CLI_MEMORY_MODE=""
        CLI_KV_MODE=""
        CLI_FROZEN_PROMPT=""
        CLI_SEMANTIC_MODE=""
        CLI_KV_QUANT=""
        CLI_LOOKUP=""
        CLI_ENGINE_MODE=""
        CLI_DISK_OFFLOAD=""
        DRY_RUN=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                -m) CLI_MODEL="$2"; shift 2 ;;
                -c) CLI_CTX="$2"; shift 2 ;;
                -t) CLI_THREADS="$2"; shift 2 ;;
                -ngl) CLI_NGL="$2"; shift 2 ;;
                -lru) CLI_LRU_MB="$2"; shift 2 ;;
                -port) CLI_PORT="$2"; shift 2 ;;
                --memory-mode) CLI_MEMORY_MODE="$2"; shift 2 ;;
                --kv-mode) CLI_KV_MODE="$2"; shift 2 ;;
                --frozen-prompt) CLI_FROZEN_PROMPT="$2"; shift 2 ;;
                --semantic-mode) CLI_SEMANTIC_MODE="$2"; shift 2 ;;
                --kv-quant) CLI_KV_QUANT="$2"; shift 2 ;;
                --lookup) CLI_LOOKUP="$2"; shift 2 ;;
                --engine-mode) CLI_ENGINE_MODE="$2"; shift 2 ;;
                --verbose) CLI_VERBOSE="true"; shift ;;
                --disk-offload) CLI_DISK_OFFLOAD="1"; shift ;;
                --dry-run) DRY_RUN=true; shift ;;
                -h|--help) usage; exit 0 ;;
                *) echo "Unknown: $1"; usage; exit 1 ;;
            esac
        done

        # Precedence: CLI > Config > Env > Default
        MODEL="${VITRIOL_MODEL:-${CLI_MODEL:-${CFG_MODEL}}}"
        CTX="${CLI_CTX:-${CFG_CTX}}"
        THREADS="${CLI_THREADS:-${CFG_THREADS}}"
        NGL="${CLI_NGL:-${CFG_NGL}}"
        PORT="${CLI_PORT:-${CFG_PORT}}"
        LRU_MB="${CLI_LRU_MB:-${CFG_LRU_MB}}"
        MODE="${VITRIOL_MODE:-${CFG_MODE}}"
        MEMORY_MODE="${VITRIOL_MEMORY_MODE:-${CLI_MEMORY_MODE:-${CFG_MEMORY_MODE}}}"
        KV_MODE="${VITRIOL_KV_MODE:-${CLI_KV_MODE:-${CFG_KV_MODE}}}"
        FROZEN_PROMPT="${VITRIOL_FROZEN_PROMPT:-${CLI_FROZEN_PROMPT:-${CFG_FROZEN_PROMPT}}}"
        SEMANTIC_MODE="${VITRIOL_SEMANTIC_MODE:-${CLI_SEMANTIC_MODE:-${CFG_SEMANTIC_MODE}}}"
        KV_QUANT="${CLI_KV_QUANT:-${CFG_KV_QUANT}}"
        LOOKUP="${CLI_LOOKUP:-${CFG_LOOKUP}}"
        ENGINE_MODE="${CLI_ENGINE_MODE:-${CLI_ENGINE_MODE:-${CFG_ENGINE_MODE}}}"
        DISK_OFFLOAD="${CLI_DISK_OFFLOAD:-0}"
        VERBOSE="${CLI_VERBOSE:-${CFG_VERBOSE}}"
        DEVICE="${CFG_DEVICE}"

        # GPU visibility
        if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
            CUDA_DEVICES="${DEVICE}"
        else
            CUDA_DEVICES="0,1"
        fi

        # Pre-flight
        if [[ ! -f "$MODEL" ]]; then
            echo "ERROR: model not found: $MODEL"
            echo "  Set with: vitriol config (option 2)"
            echo "  Or:       vitriol run -m /path/to/model.gguf"
            exit 1
        fi
        if [[ ! -x "$BINARY" ]]; then
            echo "ERROR: binary not found: $BINARY"
            echo "  Build with: cd llama.cpp && cmake -B build -DGGML_CUDA=ON ... && cmake --build build -j\$(nproc)"
            exit 1
        fi

        CAPS=$(getcap "$BINARY" 2>/dev/null || true)
        if [[ "$CAPS" != *"cap_ipc_lock"* ]]; then
            echo "WARNING: CAP_IPC_LOCK not set on binary"
            echo "  Run: vitriol setup"
            echo "  Without this, cudaHostRegister will fail"
            echo ""
        fi

        MODEL_SIZE=$(stat --format=%s "$MODEL" 2>/dev/null | numfmt --to=iec || echo "?")

        MEMORY_MODE="${VITRIOL_MEMORY_MODE:-${CFG_MEMORY_MODE}}"
        SEMANTIC_MODE="${VITRIOL_SEMANTIC_MODE:-${CFG_SEMANTIC_MODE}}"

        # Print launch banner
        clear
        [[ -f "$HEADER_FILE" ]] && cat "$HEADER_FILE"
        echo ""
        echo "═══ Launch Configuration ═══"
        echo "  Model:       $(basename "$MODEL") ($MODEL_SIZE)"
        echo "  Context:     $CTX tokens"
        echo "  Mode:        $MODE (RAM Shot + LRU cache)"
        [[ "$LRU_MB" -gt 0 ]] && echo "  LRU:         $LRU_MB MB VRAM cache"
        echo "  GPU:         Device $DEVICE (GTX 1070 Ti)"
        echo "  Memory:      $MEMORY_MODE"
        echo "  KV Mode:     $KV_MODE"
        echo "  Frozen:      $FROZEN_PROMPT"
        echo "  Semantic:    $SEMANTIC_MODE"
        echo "  KV Quant:    $KV_QUANT"
        echo "  Lookup:      $LOOKUP"
        echo "  Engine:      $ENGINE_MODE"
        echo "  Binary:      $BINARY"
        echo "  Port:        $PORT"
        [[ "$VERBOSE" == "true" ]] && echo "  Logging:     verbose"
        echo "═══════════════════════════════"
        echo ""

        if $DRY_RUN; then
            exit 0
        fi

        echo "Launching VITRIOL..."
        echo "  Model loading takes ~60s for 12 GB model"
        echo ""

        ENV_VERBOSE=""
        [[ "$VERBOSE" == "true" ]] && ENV_VERBOSE="VITRIOL_VERBOSE=1"

        exec env \
            CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
            VITRIOL_MODE="$MODE" \
            VITRIOL_LRU_MB="$LRU_MB" \
            VITRIOL_MEMORY_MODE="$MEMORY_MODE" \
            VITRIOL_KV_MODE="$KV_MODE" \
            VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
            VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
            VITRIOL_KV_QUANT="$KV_QUANT" \
            VITRIOL_LOOKUP="$LOOKUP" \
            VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
            VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
            VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
            $ENV_VERBOSE \
            "$BINARY" \
            -m "$MODEL" \
            -ngl "$NGL" \
            -c "$CTX" \
            -n 128 \
            -t "$THREADS" \
            "$@"
        ;;

    serve)
        shift
        CLI_MODEL=""
        CLI_CTX=""
        CLI_THREADS=""
        CLI_NGL=""
        CLI_LRU_MB=""
        CLI_PORT=""
        CLI_HOST=""
        CLI_PARALLEL=""
        CLI_VERBOSE=""
        CLI_MEMORY_MODE=""
        CLI_KV_MODE=""
        CLI_FROZEN_PROMPT=""
        CLI_SEMANTIC_MODE=""
        CLI_KV_QUANT=""
        CLI_LOOKUP=""
        CLI_ENGINE_MODE=""
        CLI_DISK_OFFLOAD=""
        DETACH=false
        DRY_RUN=false

        while [[ $# -gt 0 ]]; do
            case "$1" in
                -m) CLI_MODEL="$2"; shift 2 ;;
                -c) CLI_CTX="$2"; shift 2 ;;
                -t) CLI_THREADS="$2"; shift 2 ;;
                -ngl) CLI_NGL="$2"; shift 2 ;;
                -lru) CLI_LRU_MB="$2"; shift 2 ;;
                --host) CLI_HOST="$2"; shift 2 ;;
                -port) CLI_PORT="$2"; shift 2 ;;
                -p) CLI_PARALLEL="$2"; shift 2 ;;
                --memory-mode) CLI_MEMORY_MODE="$2"; shift 2 ;;
                --kv-mode) CLI_KV_MODE="$2"; shift 2 ;;
                --frozen-prompt) CLI_FROZEN_PROMPT="$2"; shift 2 ;;
                --semantic-mode) CLI_SEMANTIC_MODE="$2"; shift 2 ;;
                --kv-quant) CLI_KV_QUANT="$2"; shift 2 ;;
                --lookup) CLI_LOOKUP="$2"; shift 2 ;;
                --engine-mode) CLI_ENGINE_MODE="$2"; shift 2 ;;
                --disk-offload) CLI_DISK_OFFLOAD="1"; shift ;;
                --detach) DETACH=true; shift ;;
                --verbose) CLI_VERBOSE="true"; shift ;;
                --dry-run) DRY_RUN=true; shift ;;
                -h|--help) usage; exit 0 ;;
                *) echo "Unknown: $1"; usage; exit 1 ;;
            esac
        done

        MODEL="${VITRIOL_MODEL:-${CLI_MODEL:-${CFG_MODEL}}}"
        CTX="${CLI_CTX:-${CFG_CTX}}"
        THREADS="${CLI_THREADS:-${CFG_THREADS}}"
        NGL="${CLI_NGL:-${CFG_NGL}}"
        LRU_MB="${CLI_LRU_MB:-${CFG_LRU_MB}}"
        PORT="${CLI_PORT:-${CFG_PORT}}"
        HOST="${CLI_HOST:-${CFG_HOST}}"
        PARALLEL="${CLI_PARALLEL:-${CFG_PARALLEL}}"
        MODE="${VITRIOL_MODE:-${CFG_MODE}}"
        MEMORY_MODE="${VITRIOL_MEMORY_MODE:-${CLI_MEMORY_MODE:-${CFG_MEMORY_MODE}}}"
        KV_MODE="${VITRIOL_KV_MODE:-${CLI_KV_MODE:-${CFG_KV_MODE}}}"
        FROZEN_PROMPT="${VITRIOL_FROZEN_PROMPT:-${CLI_FROZEN_PROMPT:-${CFG_FROZEN_PROMPT}}}"
        SEMANTIC_MODE="${VITRIOL_SEMANTIC_MODE:-${CLI_SEMANTIC_MODE:-${CFG_SEMANTIC_MODE}}}"
        KV_QUANT="${CLI_KV_QUANT:-${CFG_KV_QUANT}}"
        LOOKUP="${CLI_LOOKUP:-${CFG_LOOKUP}}"
        ENGINE_MODE="${CLI_ENGINE_MODE:-${CLI_ENGINE_MODE:-${CFG_ENGINE_MODE}}}"
        DISK_OFFLOAD="${CLI_DISK_OFFLOAD:-0}"
        VERBOSE="${CLI_VERBOSE:-${CFG_VERBOSE}}"
        DEVICE="${CFG_DEVICE}"

        if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
            CUDA_DEVICES="${DEVICE}"
        else
            CUDA_DEVICES="0,1"
        fi

        if [[ ! -f "$MODEL" ]]; then
            echo "ERROR: model not found: $MODEL"
            echo "  Set with: vitriol config (option 2)"
            exit 1
        fi
        if [[ ! -x "$SERVER_BINARY" ]]; then
            echo "ERROR: server binary not found: $SERVER_BINARY"
            echo "  Build with: cd llama.cpp && cmake -B build -DGGML_CUDA=ON ... && cmake --build build -j\$(nproc)"
            exit 1
        fi

        # Check caps for server binary too
        SERVER_CAPS=$(getcap "$SERVER_BINARY" 2>/dev/null || true)
        if [[ "$SERVER_CAPS" != *"cap_ipc_lock"* ]]; then
            echo "WARNING: CAP_IPC_LOCK not set on $SERVER_BINARY"
            echo "  Run: vitriol setup"
            echo "  Without this, cudaHostRegister will fail"
            echo ""
        fi

        MODEL_SIZE=$(stat --format=%s "$MODEL" 2>/dev/null | numfmt --to=iec || echo "?")

        clear
        [[ -f "$HEADER_FILE" ]] && cat "$HEADER_FILE"
        echo ""
        echo "═══ VITRIOL Server ═══"
        echo "  Model:       $(basename "$MODEL") ($MODEL_SIZE)"
        echo "  Context:     $CTX tokens"
        echo "  Mode:        $MODE (RAM Shot + LRU cache)"
        [[ "$LRU_MB" -gt 0 ]] && echo "  LRU:         $LRU_MB MB VRAM cache"
        echo "  GPU:         Device $DEVICE (GTX 1070 Ti)"
        echo "  Memory:      $MEMORY_MODE"
        echo "  KV Mode:     $KV_MODE"
        echo "  Frozen:      $FROZEN_PROMPT"
        echo "  Semantic:    $SEMANTIC_MODE"
        echo "  KV Quant:    $KV_QUANT"
        echo "  Lookup:      $LOOKUP"
        echo "  Engine:      $ENGINE_MODE"
        if [[ "$MEMORY_MODE" == "on" ]]; then
            LLAMA_PORT=$((PORT - 1))
            echo "  Server:      http://${HOST}:${LLAMA_PORT} (llama-server, internal)"
            echo "  Proxy:       http://${HOST}:${PORT} (VITRIOL shim, memory intercept)"
        else
            echo "  Server:      http://${HOST}:${PORT}"
        fi
        echo "  Slots:     $PARALLEL parallel"
        [[ "$VERBOSE" == "true" ]] && echo "  Logging:   verbose"
        echo "═══════════════════════════"
        echo ""

        if $DRY_RUN; then
            exit 0
        fi

        ENV_VERBOSE=""
        [[ "$VERBOSE" == "true" ]] && ENV_VERBOSE="VITRIOL_VERBOSE=1"

        # KV cache quant args (pass to llama-server as --cache-type-k/v)
        KV_CACHE_ARGS=""
        [[ "$KV_QUANT" != "f16" ]] && KV_CACHE_ARGS="--cache-type-k $KV_QUANT --cache-type-v $KV_QUANT"
        # Flash Attention is required for V cache quantization and generally faster
        FA_ARGS="-fa on"

        if $DETACH; then
            echo "Starting server in background..."
            mkdir -p "$CONFIG_DIR"
            SHIM_DIR="$(dirname "$SCRIPT_DIR")/libvitriol"
            export LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

            if [[ "$MEMORY_MODE" == "on" ]]; then
                LLAMA_PORT=$((PORT - 1))
                # Start llama-server on internal port
                env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    nohup "$SERVER_BINARY" \
                        -m "$MODEL" \
                        -ngl "$NGL" \
                        -c "$CTX" \
                        --host "$HOST" \
                        --port "$LLAMA_PORT" \
                        --parallel "$PARALLEL" \
                        --no-mmap \
                        -t "$THREADS" \
                            $KV_CACHE_ARGS $FA_ARGS \
                            "$@" &>"${CONFIG_DIR}/llama-server.log" &
                echo $! > "${CONFIG_DIR}/llama-server.pid"
                echo "  llama-server PID: $! (internal port $LLAMA_PORT)"

                # Start Python shim on external port
                env \
                    VITRIOL_MEMORY_MODE=on \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    LLAMA_API_URL="http://${HOST}:${LLAMA_PORT}/v1/chat/completions" \
                    LLAMA_STATUS_URL="http://${HOST}:${LLAMA_PORT}/health" \
                    SHIM_PORT="$PORT" \
                    nohup python3 "$SHIM_DIR/vitriol_shim.py" \
                        &>"${CONFIG_DIR}/shim.log" &
                echo $! > "${CONFIG_DIR}/shim.pid"
                echo "  VITRIOL shim PID: $! (memory on port $PORT)"
            else
                # Start llama-server on external port directly
                env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    nohup "$SERVER_BINARY" \
                        -m "$MODEL" \
                        -ngl "$NGL" \
                        -c "$CTX" \
                        --host "$HOST" \
                        --port "$PORT" \
                        --parallel "$PARALLEL" \
                        --no-mmap \
                        -t "$THREADS" \
                        $KV_CACHE_ARGS $FA_ARGS \
                        "$@" &>"${CONFIG_DIR}/server.log" &
                echo $! > "${CONFIG_DIR}/server.pid"
                echo "  Server PID: $!"
            fi

            echo "  Log dir:   ${CONFIG_DIR}"
            echo ""
            echo "  curl http://${HOST}:${PORT}/v1/chat/completions \\"
            echo "    -H \"Content-Type: application/json\" \\"
            echo "    -H \"X-Project-Id: my_project\" \\"
            echo "    -H \"X-Session-Id: my_session\" \\"
            echo "    -d '{\"messages\":[{\"role\":\"user\",\"content\":\"Hello\"}],\"max_tokens\":50}'"
        else
            echo "Starting server (Ctrl+C to stop)..."
            echo ""
            export LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

            if [[ "$MEMORY_MODE" == "on" ]]; then
                LLAMA_PORT=$((PORT - 1))
                SHIM_DIR="$(dirname "$SCRIPT_DIR")/libvitriol"

                # Start llama-server in background on internal port
                env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    "$SERVER_BINARY" \
                        -m "$MODEL" \
                        -ngl "$NGL" \
                        -c "$CTX" \
                        --host "$HOST" \
                        --port "$LLAMA_PORT" \
                        --parallel "$PARALLEL" \
                        --no-mmap \
                        -t "$THREADS" $KV_CACHE_ARGS $FA_ARGS &
                LLAMA_PID=$!
                echo "  llama-server running (PID $LLAMA_PID, internal port $LLAMA_PORT)"

                # Trap Ctrl+C to clean up llama-server
                trap "echo 'Shutting down...'; kill $LLAMA_PID 2>/dev/null; exit 0" INT TERM

                # Start shim in foreground on external port
                echo "  Starting VITRIOL memory shim on port $PORT..."
                env \
                    VITRIOL_MEMORY_MODE=on \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    LLAMA_API_URL="http://${HOST}:${LLAMA_PORT}/v1/chat/completions" \
                    LLAMA_STATUS_URL="http://${HOST}:${LLAMA_PORT}/health" \
                    SHIM_PORT="$PORT" \
                    python3 "$SHIM_DIR/vitriol_shim.py"
            else
                exec env \
                    CUDA_VISIBLE_DEVICES="$CUDA_DEVICES" \
                    VITRIOL_MODE="$MODE" \
                    VITRIOL_LRU_MB="$LRU_MB" \
                    VITRIOL_KV_MODE="$KV_MODE" \
                    VITRIOL_FROZEN_PROMPT="$FROZEN_PROMPT" \
                    VITRIOL_SEMANTIC_MODE="$SEMANTIC_MODE" \
                    VITRIOL_KV_QUANT="$KV_QUANT" \
                    VITRIOL_LOOKUP="$LOOKUP" \
                    VITRIOL_ENGINE_MODE="$ENGINE_MODE" \
                    VITRIOL_DISK_OFFLOAD="$DISK_OFFLOAD" \
                    VITRIOL_MODEL_PATH="$MODEL" \
                    LD_LIBRARY_PATH="${LLAMA_DIR}/build/bin" \
                    $ENV_VERBOSE \
                    "$SERVER_BINARY" \
                    -m "$MODEL" \
                    -ngl "$NGL" \
                    -c "$CTX" \
                    --host "$HOST" \
                    --port "$PORT" \
                    --parallel "$PARALLEL" \
                    --no-mmap \
                    -t "$THREADS" \
                    $KV_CACHE_ARGS $FA_ARGS \
                    "$@"
            fi
        fi
        ;;

    stop)
        STOPPED=false

        # Stop shim (memory mode)
        SHIM_PID_FILE="${CONFIG_DIR}/shim.pid"
        if [[ -f "$SHIM_PID_FILE" ]]; then
            PID=$(cat "$SHIM_PID_FILE")
            echo "→ Stopping VITRIOL shim (PID $PID)..."
            kill "$PID" 2>/dev/null && echo "  ✓ Shim stopped" || echo "  (shim not running)"
            rm -f "$SHIM_PID_FILE"
            STOPPED=true
        fi

        # Stop llama-server (internal port in memory mode, or standard)
        LLAMA_PID_FILE="${CONFIG_DIR}/llama-server.pid"
        if [[ -f "$LLAMA_PID_FILE" ]]; then
            PID=$(cat "$LLAMA_PID_FILE")
            echo "→ Stopping llama-server (PID $PID)..."
            kill "$PID" 2>/dev/null && echo "  ✓ llama-server stopped" || echo "  (llama-server not running)"
            rm -f "$LLAMA_PID_FILE"
            STOPPED=true
        fi

        # Stop standard server
        PID_FILE="${CONFIG_DIR}/server.pid"
        if [[ -f "$PID_FILE" ]]; then
            PID=$(cat "$PID_FILE")
            echo "→ Stopping server (PID $PID)..."
            kill "$PID" 2>/dev/null && echo "  ✓ Stopped" || echo "  (not running)"
            rm -f "$PID_FILE"
            STOPPED=true
        fi

        if ! $STOPPED; then
            echo "→ No PID files found. Searching for running processes..."
            pkill -f "llama-server.*Qwen3" 2>/dev/null && echo "  ✓ llama-server stopped" || true
            pkill -f "vitriol_shim" 2>/dev/null && echo "  ✓ VITRIOL shim stopped" || true
        fi
        ;;

    config)
        shift
        case "${1:-}" in
            show)  config_show ;;
            init)  config_init ;;
            reset) config_reset ;;
            edit)  ${EDITOR:-vim} "$CONFIG_FILE" ;;
            set)   shift; config_set "$1" "$2" ;;
            *)     tui_main_menu ;;
        esac
        ;;

    setup)
        setup_caps "$BINARY"
        if [[ -x "$SERVER_BINARY" ]]; then
            setup_caps "$SERVER_BINARY"
        fi
        ;;

    help|--help|-h)
        usage
        ;;

    *)
        usage
        exit 1
        ;;
esac
