#!/bin/bash
# VITRIOL — MoE Expert Offloading via PCIe DMA
#
# Usage:
#   vitriol run              launch inference
#   vitriol config           interactive config TUI
#   vitriol setup            set CAP_IPC_LOCK capability
#   vitriol help             this message

set -euo pipefail

# ── paths ────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LLAMA_DIR="${PROJECT_DIR}/llama.cpp"
BINARY="${LLAMA_DIR}/build/bin/llama-cli"
SERVER_BINARY="${LLAMA_DIR}/build/bin/llama-server"
HEADER_FILE="${PROJECT_DIR}/assets/vitriol-header.txt"
CONFIG_DIR="${HOME}/.vitriol"
CONFIG_FILE="${CONFIG_DIR}/config"

# ── defaults ─────────────────────────────────────────────────────
DEFAULT_MODEL="/mnt/data/ai/koboldcpp/Qwen3.6-35B-A3B-UD-Q2_K_XL.gguf"
DEFAULT_CTX=262144
DEFAULT_THREADS=4
DEFAULT_NGL=99
DEFAULT_PORT=8279
DEFAULT_HOST="0.0.0.0"
DEFAULT_PARALLEL=4
DEFAULT_MODE="stream"
DEFAULT_LRU_MB=0
DEFAULT_DEVICE=0
DEFAULT_EXCLUDE_SECONDARY=true
DEFAULT_VERBOSE=false
DEFAULT_MEMORY_MODE="off"
DEFAULT_KV_MODE="standard"
DEFAULT_FROZEN_PROMPT="off"
DEFAULT_SEMANTIC_MODE="off"
DEFAULT_KV_QUANT="q4_0"
DEFAULT_KV_QUANT_V="f16"
DEFAULT_LOOKUP=0
DEFAULT_ENGINE_MODE="vitriol-dma"
DEFAULT_SPEC_TYPE=""
DEFAULT_SPEC_DRAFT_N_MAX=0
DEFAULT_CHIMERA_MODE="auto"
DEFAULT_EXPERT_COUNT=0
DEFAULT_OUTPUT_CACHE="off"
DEFAULT_PREDICTIVE_PREFETCH="off"
DEFAULT_PIN_FIRST_N_LAYERS=0
DEFAULT_PRUNE_EXPERTS=0
DEFAULT_REASONING="off"

# ── config vars (set by parse_config) ────────────────────────────
CFG_DEVICE="$DEFAULT_DEVICE"
CFG_EXCLUDE_SECONDARY="$DEFAULT_EXCLUDE_SECONDARY"
CFG_MODEL="$DEFAULT_MODEL"
CFG_CTX="$DEFAULT_CTX"
CFG_THREADS="$DEFAULT_THREADS"
CFG_NGL="$DEFAULT_NGL"
CFG_MODE="$DEFAULT_MODE"
CFG_LRU_MB="$DEFAULT_LRU_MB"
CFG_VERBOSE="$DEFAULT_VERBOSE"
CFG_PORT="$DEFAULT_PORT"
CFG_HOST="$DEFAULT_HOST"
CFG_PARALLEL="$DEFAULT_PARALLEL"
CFG_MEMORY_MODE="$DEFAULT_MEMORY_MODE"
CFG_KV_MODE="$DEFAULT_KV_MODE"
CFG_FROZEN_PROMPT="$DEFAULT_FROZEN_PROMPT"
CFG_SEMANTIC_MODE="$DEFAULT_SEMANTIC_MODE"
CFG_KV_QUANT="$DEFAULT_KV_QUANT"
CFG_KV_QUANT_V="$DEFAULT_KV_QUANT_V"
CFG_LOOKUP="$DEFAULT_LOOKUP"
CFG_ENGINE_MODE="$DEFAULT_ENGINE_MODE"
CFG_SPEC_TYPE="$DEFAULT_SPEC_TYPE"
CFG_SPEC_DRAFT_N_MAX="$DEFAULT_SPEC_DRAFT_N_MAX"
CFG_EXPERT_COUNT="$DEFAULT_EXPERT_COUNT"
CFG_OUTPUT_CACHE="$DEFAULT_OUTPUT_CACHE"
CFG_PREDICTIVE_PREFETCH="$DEFAULT_PREDICTIVE_PREFETCH"
CFG_PIN_FIRST_N_LAYERS="$DEFAULT_PIN_FIRST_N_LAYERS"
CFG_PRUNE_EXPERTS="$DEFAULT_PRUNE_EXPERTS"
CFG_REASONING="$DEFAULT_REASONING"
CFG_CHIMERA_MODE="$DEFAULT_CHIMERA_MODE"

# ═════════════════════════════════════════════════════════════════
# CONFIG PARSING
# ═════════════════════════════════════════════════════════════════

parse_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        return 0
    fi
    local section=""
    while IFS= read -r line; do
        line="${line%%#*}"        # strip comments
        line="${line##*( )}"      # strip leading space (shopt extglob may not be on)
        line="${line%%*( )}"      # strip trailing space
        [[ -z "$line" ]] && continue
        if [[ "$line" =~ ^\[([^\]]+)\]$ ]]; then
            section="${BASH_REMATCH[1]}"
            continue
        fi
        if [[ "$line" =~ ^([a-zA-Z_]+)[[:space:]]*=[[:space:]]*(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local val="${BASH_REMATCH[2]}"
            # strip quotes
            val="${val#\"}"; val="${val%\"}"
            val="${val#\'}"; val="${val%\'}"
            case "${section}.${key}" in
                gpu.device)            CFG_DEVICE="$val" ;;
                gpu.exclude_secondary) CFG_EXCLUDE_SECONDARY="$val" ;;
                model.path)            CFG_MODEL="$val" ;;
                model.context)         CFG_CTX="$val" ;;
                model.threads)         CFG_THREADS="$val" ;;
                model.ngl)             CFG_NGL="$val" ;;
                vitriol.mode)          CFG_MODE="$val" ;;
                vitriol.lru_mb)        CFG_LRU_MB="$val" ;;
                vitriol.verbose)       CFG_VERBOSE="$val" ;;
                server.host)           CFG_HOST="$val" ;;
                server.parallel)       CFG_PARALLEL="$val" ;;
                server.port)           CFG_PORT="$val" ;;
                memory.mode)           CFG_MEMORY_MODE="$val" ;;
                memory.semantic_mode)  CFG_SEMANTIC_MODE="$val" ;;
                kv.mode)               CFG_KV_MODE="$val" ;;
                kv.frozen_prompt)      CFG_FROZEN_PROMPT="$val" ;;
                kv.quant_mode)         CFG_KV_QUANT="$val" ;;
                kv.quant_mode_v)       CFG_KV_QUANT_V="$val" ;;
                lookup_tokens)         CFG_LOOKUP="$val" ;;
                engine.mode)             CFG_ENGINE_MODE="$val" ;;
                spec.type)             CFG_SPEC_TYPE="$val" ;;
                spec.draft_n_max)      CFG_SPEC_DRAFT_N_MAX="$val" ;;
                model.expert_count)    CFG_EXPERT_COUNT="$val" ;;
                vitriol.output_cache)  CFG_OUTPUT_CACHE="$val" ;;
                 vitriol.predictive_prefetch) CFG_PREDICTIVE_PREFETCH="$val" ;;
                 vitriol.pin_first_n_layers) CFG_PIN_FIRST_N_LAYERS="$val" ;;
                 vitriol.prune_experts)     CFG_PRUNE_EXPERTS="$val" ;;
                 vitriol.reasoning)         CFG_REASONING="$val" ;;
                chimera.mode)            CFG_CHIMERA_MODE="$val" ;;
            esac
        fi
    done < "$CONFIG_FILE"
}

write_config() {
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<CFGEOF
# VITRIOL Configuration
# Generated by vitriol config
# Uncomment and edit, or use: vitriol config

[gpu]
# CUDA device index to use
device = $CFG_DEVICE
# Exclude secondary GPU (GTX 960, CC 5.2 lacks kernel images)
exclude_secondary = $CFG_EXCLUDE_SECONDARY

[model]
# Path to GGUF model file
path = $CFG_MODEL
# Context window size
context = $CFG_CTX
# CPU threads for prompt processing
threads = $CFG_THREADS
# GPU layers to offload
ngl = $CFG_NGL
# Expert count override (0 = model default, 4-8 recommended)
expert_count = $CFG_EXPERT_COUNT

[vitriol]
# Operation mode: stream | sync | async | off
mode = $CFG_MODE
# LRU VRAM cache in MB (0 to disable; only effective with FP16/FP32 experts)
lru_mb = $CFG_LRU_MB
# Verbose logging
verbose = $CFG_VERBOSE
# Expert output caching: on | off (approximate — reuses previous token's expert outputs)
output_cache = $CFG_OUTPUT_CACHE
# Predictive prefetching: on | off (cross-layer + temporal heuristic, DMA stream overlap)
predictive_prefetch = $CFG_PREDICTIVE_PREFETCH
# Expert pinning: pin first N layers' expert tensors in VRAM (0 = off)
#   Pins all 256 experts per pinned layer into VRAM at first use.
#   Targets the fast MMVQ/MMQ/MMF kernel path — auto-disables output cache.
#   Recommended: 5-15. Uses ~220 MB per layer. Needs KV offload for >10.
pin_first_n_layers = $CFG_PIN_FIRST_N_LAYERS
# Top-K expert pruning: drop bottom N of 8 active experts before compute
#   0 = off (default), 2 = compute 6 experts, 4 = compute 4 experts
#   Experimental: may affect output quality, especially for creative tasks.
prune_experts = $CFG_PRUNE_EXPERTS
# Reasoning/thinking mode: on | off (off disables thinking, required for Qwen3.6)
reasoning = $CFG_REASONING

[server]
# API host address
host = $CFG_HOST
# API port
port = $CFG_PORT
# Parallel slots for concurrent requests
parallel = $CFG_PARALLEL

[memory]
# Emulated memory mode: on | off
mode = $CFG_MEMORY_MODE
# Semantic search mode: on | off (requires sentence-transformers)
semantic_mode = $CFG_SEMANTIC_MODE

[kv]
# KV cache mode: standard | offload | sparse
mode = $CFG_KV_MODE
# KV cache quantization: f16 | q8_0 | q4_0 (affects K cache only)
quant_mode = $CFG_KV_QUANT
# V cache quantization: f16 (default, safe) | q8_0 | q4_0 (RISK: quantizing V causes garbage output)
quant_mode_v = $CFG_KV_QUANT_V

# Frozen prompt: on | off (keep system prompt static to avoid re-prefix)
frozen_prompt = $CFG_FROZEN_PROMPT

[engine]
# Execution mode: vitriol-dma | native
mode = $CFG_ENGINE_MODE

[lookup]
# Prompt lookup decoding tokens (0 = disabled)
tokens = $CFG_LOOKUP

[spec]
# Speculative decoding type: mtp | draft (leave empty to disable)
type = $CFG_SPEC_TYPE
# Draft tokens to generate for speculative decoding (e.g. 2 for MTP)
draft_n_max = $CFG_SPEC_DRAFT_N_MAX

[chimera]
# Backend routing: auto | cuda | vulkan | off
#   auto   → Chimera if Vulkan available, else CUDA-only
#   cuda   → CUDA-only (experts via VITRIOL DMA)
#   vulkan → Vulkan-only (all tensors via VK_EXT_external_memory_host)
#   off    → CUDA-only (same as cuda)
mode = $CFG_CHIMERA_MODE
CFGEOF
}

config_init() {
    write_config
    echo "✓ Config written to $CONFIG_FILE"
}

config_show() {
    local box_w=44
    local inner=$((box_w - 4))
    local line
    print_row() {
        local label="$1" val="$2"
        local display="${val}"
        if [[ ${#display} -gt $inner ]]; then
            display="${display:0:$((inner-3))}..."
        fi
        printf "║  %-*s ║\n" "$inner" "${label}${display}"
    }

    echo "╔$(printf '═%.0s' $(seq 1 $box_w))╗"
    printf "║  %-*s ║\n" "$inner" "VITRIOL Configuration"
    echo "╠$(printf '═%.0s' $(seq 1 $box_w))╣"
    print_row "GPU Device:            " "${CFG_DEVICE}"
    print_row "Exclude Secondary:     " "${CFG_EXCLUDE_SECONDARY}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    local mtp_label=""
    model_has_mtp "$CFG_MODEL" && mtp_label=" [MTP]"
    print_row "Model:                 " "$(basename "${CFG_MODEL}" 2>/dev/null || echo "?")${mtp_label}"
    print_row "Path:                  " "${CFG_MODEL}"
    print_row "Context:               " "${CFG_CTX}"
    print_row "Threads:               " "${CFG_THREADS}"
    print_row "GPU Layers (ngl):      " "${CFG_NGL}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "VITRIOL Mode:          " "${CFG_MODE}"
    print_row "LRU Cache (MB):        " "${CFG_LRU_MB} (inactive for Q2_K; FP16 only)"
    print_row "Verbose:               " "${CFG_VERBOSE}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Memory Mode:           " "${CFG_MEMORY_MODE}"
    print_row "  Semantic Search:     " "${CFG_SEMANTIC_MODE}"
    print_row "KV Mode:               " "${CFG_KV_MODE}"
    print_row "Frozen Prompt:         " "${CFG_FROZEN_PROMPT}"
    print_row "K Quant:               " "${CFG_KV_QUANT}"
    print_row "V Quant:               " "${CFG_KV_QUANT_V}"
    print_row "Prompt Lookup:         " "${CFG_LOOKUP}"
    print_row "Expert Count:          " "${CFG_EXPERT_COUNT:-0} (0=default)"
    print_row "Output Cache:          " "${CFG_OUTPUT_CACHE}"
    print_row "Predictive Prefetch:   " "${CFG_PREDICTIVE_PREFETCH}"
    print_row "Expert Pin Layers:     " "${CFG_PIN_FIRST_N_LAYERS:-0} (0=off)"
    if [[ "${CFG_PRUNE_EXPERTS:-0}" -gt 0 ]]; then
        local keep=$((8 - CFG_PRUNE_EXPERTS))
        print_row "Expert Pruning:        " "drop ${CFG_PRUNE_EXPERTS} (keep ${keep})"
    fi
    print_row "Reasoning:             " "${CFG_REASONING:-on}"
    if [[ -n "$CFG_SPEC_TYPE" ]]; then
        local mtp_ok=""
        model_has_mtp "$CFG_MODEL" && mtp_ok=" (MTP detected)"
        print_row "Spec Type:             " "${CFG_SPEC_TYPE}${mtp_ok}"
        [[ "${CFG_SPEC_DRAFT_N_MAX:-0}" -gt 0 ]] && print_row "Spec Draft N-Max:      " "${CFG_SPEC_DRAFT_N_MAX}"
    fi
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Engine Mode:           " "${CFG_ENGINE_MODE}"
    echo "╠$(printf '─%.0s' $(seq 1 $box_w))╣"
    print_row "Server Host:           " "${CFG_HOST}"
    print_row "Server Port:           " "${CFG_PORT}"
    print_row "Parallel Slots:        " "${CFG_PARALLEL}"
    echo "╚$(printf '═%.0s' $(seq 1 $box_w))╝"
}

config_reset() {
    CFG_DEVICE="$DEFAULT_DEVICE"
    CFG_EXCLUDE_SECONDARY="$DEFAULT_EXCLUDE_SECONDARY"
    CFG_PIN_FIRST_N_LAYERS="$DEFAULT_PIN_FIRST_N_LAYERS"
    CFG_PRUNE_EXPERTS="$DEFAULT_PRUNE_EXPERTS"
    CFG_REASONING="$DEFAULT_REASONING"
    CFG_MODEL="$DEFAULT_MODEL"
    CFG_CTX="$DEFAULT_CTX"
    CFG_THREADS="$DEFAULT_THREADS"
    CFG_NGL="$DEFAULT_NGL"
    CFG_MODE="$DEFAULT_MODE"
    CFG_LRU_MB="$DEFAULT_LRU_MB"
    CFG_VERBOSE="$DEFAULT_VERBOSE"
    CFG_PORT="$DEFAULT_PORT"
    CFG_HOST="$DEFAULT_HOST"
    CFG_PARALLEL="$DEFAULT_PARALLEL"
    write_config
    echo "✓ Config reset to defaults"
}

config_set() {
    local key="$1" val="$2"
    case "$key" in
        gpu.device)            CFG_DEVICE="$val" ;;
        gpu.exclude_secondary) CFG_EXCLUDE_SECONDARY="$val" ;;
        model.path)            CFG_MODEL="$val" ;;
        model.context)         CFG_CTX="$val" ;;
        model.threads)         CFG_THREADS="$val" ;;
        model.ngl)             CFG_NGL="$val" ;;
        model.expert_count)    CFG_EXPERT_COUNT="$val" ;;
        vitriol.mode)          CFG_MODE="$val" ;;
        vitriol.lru_mb)        CFG_LRU_MB="$val" ;;
        vitriol.verbose)       CFG_VERBOSE="$val" ;;
        vitriol.output_cache)  CFG_OUTPUT_CACHE="$val" ;;
        vitriol.predictive_prefetch) CFG_PREDICTIVE_PREFETCH="$val" ;;
        vitriol.pin_first_n_layers) CFG_PIN_FIRST_N_LAYERS="$val" ;;
        vitriol.prune_experts)     CFG_PRUNE_EXPERTS="$val" ;;
        vitriol.reasoning)         CFG_REASONING="$val" ;;
        server.host)           CFG_HOST="$val" ;;
        server.parallel)       CFG_PARALLEL="$val" ;;
        server.port)           CFG_PORT="$val" ;;
        memory.mode)           CFG_MEMORY_MODE="$val" ;;
        memory.semantic_mode)  CFG_SEMANTIC_MODE="$val" ;;
        kv.mode)               CFG_KV_MODE="$val" ;;
        kv.quant_mode)         CFG_KV_QUANT="$val" ;;
        lookup_tokens)          CFG_LOOKUP="$val" ;;
        engine.mode)           CFG_ENGINE_MODE="$val" ;;
        spec.type)             CFG_SPEC_TYPE="$val" ;;
        spec.draft_n_max)      CFG_SPEC_DRAFT_N_MAX="$val" ;;
        frozen_prompt)         CFG_FROZEN_PROMPT="$val" ;;
        *) echo "Unknown key: $key"; return 1 ;;
    esac
    write_config
    echo "✓ $key = $val"
}

# ═════════════════════════════════════════════════════════════════
# MTP DETECTION
# ═════════════════════════════════════════════════════════════════

model_has_mtp() {
    local model_path="$1"
    if [[ ! -f "$model_path" ]]; then
        return 1
    fi
    grep -q "nextn_predict_layers" < <(head -c 1M "$model_path") 2>/dev/null
}

# ═════════════════════════════════════════════════════════════════
# HEADER
# ═════════════════════════════════════════════════════════════════

print_header() {
    local logo_file="${SCRIPT_DIR}/../assets/ansi-logo.txt"
    if [[ -f "$logo_file" ]]; then
        # ANSI logo with green/gold VITRIOL art
        echo -e "$(grep -v '^#' "$logo_file" | head -1 | sed "s/echo -e '//" | sed "s/'$//")"
    elif [[ -f "$HEADER_FILE" ]]; then
        cat "$HEADER_FILE"
    else
        echo "VITRIOL — MoE Expert Offloading"
    fi
    echo ""
}

# ═════════════════════════════════════════════════════════════════
# TUI MENU
# ═════════════════════════════════════════════════════════════════

tui_main_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║           Configuration Menu             ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) GPU Settings"
        printf "║  %-37s ║\n" "2) Model Settings"
        printf "║  %-37s ║\n" "3) VITRIOL Mode"
        printf "║  %-37s ║\n" "4) Memory Settings"
        printf "║  %-37s ║\n" "5) Engine Settings"
        printf "║  %-37s ║\n" "6) Server Settings"
        printf "║  %-37s ║\n" "7) Show Current Config"
        printf "║  %-37s ║\n" "8) Reset to Defaults"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-9/q]: " choice
        case "$choice" in
            1) tui_gpu_menu ;;
            2) tui_model_menu ;;
            3) tui_vitriol_menu ;;
            4) tui_memory_menu ;;
            5) tui_engine_menu ;;
            6) tui_server_menu ;;
            7) clear; print_header; config_show; echo ""; read -r -p "Press Enter to continue..." ;;
            8) config_reset; echo ""; read -r -p "Press Enter to continue..." ;;
            q|Q) clear; exit 0 ;;
            *) ;;
        esac
    done
}

tui_gpu_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║            GPU Settings                  ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Device Index     [${CFG_DEVICE}]"
        printf "║  %-37s ║\n" "2) Exclude Secondary [${CFG_EXCLUDE_SECONDARY}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-2/b/q]: " choice
        case "$choice" in
            1)
                read -r -p "Enter device index (0-7): " val
                if [[ "$val" =~ ^[0-7]$ ]]; then
                    config_set gpu.device "$val"
                else
                    echo "Invalid (must be 0-7)"; sleep 1
                fi
                ;;
            2)
                if [[ "$CFG_EXCLUDE_SECONDARY" == "true" ]]; then
                    config_set gpu.exclude_secondary "false"
                else
                    config_set gpu.exclude_secondary "true"
                fi
                ;;
            5)
                echo "Options: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_model_menu() {
    while true; do
        local mtp_indicator mtp_label
        if model_has_mtp "$CFG_MODEL"; then
            mtp_indicator="MTP ready"
        else
            mtp_indicator="no MTP"
        fi
        if [[ -n "$CFG_SPEC_TYPE" ]]; then
            mtp_label="Spec Type [${CFG_SPEC_TYPE}]"
        else
            mtp_label="Spec Type [off]"
        fi
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Model Settings                  ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Model Path       [$(basename "${CFG_MODEL}" 2>/dev/null || echo "?" )]"
        printf "║  %-37s ║\n" "   (${mtp_indicator})"
        printf "║  %-37s ║\n" "2) Context Window   [${CFG_CTX}]"
        printf "║  %-37s ║\n" "3) Threads          [${CFG_THREADS}]"
        printf "║  %-37s ║\n" "4) GPU Layers (ngl) [${CFG_NGL}]"
        printf "║  %-37s ║\n" "5) Expert Count     [${CFG_EXPERT_COUNT:-0}]"
        printf "║  %-37s ║\n" "6) Output Cache     [${CFG_OUTPUT_CACHE}]"
        printf "║  %-37s ║\n" "7) ${mtp_label}"
        if [[ -n "$CFG_SPEC_TYPE" ]]; then
            printf "║  %-37s ║\n" "8) Draft N-Max      [${CFG_SPEC_DRAFT_N_MAX:-0}]"
        fi
        local prune_keep=$((8 - ${CFG_PRUNE_EXPERTS:-0}))
        printf "║  %-37s ║\n" "11) Expert Pruning   [${CFG_PRUNE_EXPERTS:-0} (keep ${prune_keep})]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-11/b/q]: " choice
        case "$choice" in
            1)
                echo "Enter new model path (Tab completion available):"
                read -r -e -p "> " val
                val="${val/#\~/$HOME}"
                if [[ -n "$val" ]]; then
                    config_set model.path "$val"
                fi
                ;;
            2)
                read -r -p "Enter context window (512-1000000): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 512 && val <= 1000000)); then
                    config_set model.context "$val"
                else
                    echo "Invalid (must be 512-1000000)"; sleep 1
                fi
                ;;
            3)
                read -r -p "Enter threads (1-32): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 32)); then
                    config_set model.threads "$val"
                else
                    echo "Invalid (must be 1-32)"; sleep 1
                fi
                ;;
            4)
                read -r -p "Enter GPU layers/ngl (1-99): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 99)); then
                    config_set model.ngl "$val"
                else
                    echo "Invalid (must be 1-99)"; sleep 1
                fi
                ;;
            5)
                echo "Expert count override (0 = model default, 4-8 recommended)"
                read -r -p "Enter expert count: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val == 0 || (val >= 1 && val <= 256))); then
                    config_set model.expert_count "$val"
                else
                    echo "Invalid (must be 0-256, 0=default)"; sleep 1
                fi
                ;;
            6)
                echo "Expert output caching: on | off (approximate — reuses previous token outputs)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set vitriol.output_cache "$val" ;;
                    *) echo "Invalid (on|off)"; sleep 1 ;;
                esac
                ;;
            7)
                echo "Speculative decoding type: mtp | draft (leave empty to disable)"
                read -r -p "Enter type: " val
                case "$val" in
                    mtp|draft|"") config_set spec.type "$val" ;;
                    *) echo "Invalid type (mtp, draft, or empty)"; sleep 1 ;;
                esac
                ;;
            8)
                echo "Number of tokens to draft per cycle (1-12, recommended: 2)"
                read -r -p "Enter draft N: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 1 && val <= 12)); then
                    config_set spec.draft_n_max "$val"
                else
                    echo "Invalid (must be 1-12)"; sleep 1
                fi
                ;;
            9)
                echo "KV cache quantization: f16 (FP16, default) | q8_0 (8-bit) | q4_0 (4-bit)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            10)
                echo "Prompt lookup decoding tokens (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            11)
                echo ""
                echo "Top-K Expert Pruning: drops the bottom N of 8 active experts"
                echo "before the matmul. Halves compute when N=4."
                echo ""
                echo "  0 = off (all 8 experts computed)"
                echo "  2 = compute 6 experts (-25% compute)"
                echo "  4 = compute 4 experts (-50% compute)"
                echo ""
                echo "  Experimental: may affect output quality, especially for"
                echo "  creative writing or complex reasoning."
                echo ""
                read -r -p "Enter experts to prune (0-7): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 7)); then
                    if [[ "$val" -gt 0 ]]; then
                        echo ""
                        echo "  ⚠ Pruning enabled: dropping $val of 8 experts."
                        echo "  Keep an eye on generation quality."
                    fi
                    config_set vitriol.prune_experts "$val"
                else
                    echo "Invalid (must be 0-7)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_vitriol_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          VITRIOL Mode Settings           ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Operation Mode   [${CFG_MODE}]"
        printf "║  %-37s ║\n" "2) LRU Cache (MB)   [${CFG_LRU_MB}] (FP16 only)"
        printf "║  %-37s ║\n" "3) Verbose Logging  [${CFG_VERBOSE}]"
        printf "║  %-37s ║\n" "4) Predictive Prefetch [${CFG_PREDICTIVE_PREFETCH}]"
        printf "║  %-37s ║\n" "5) Expert Pin Layers  [${CFG_PIN_FIRST_N_LAYERS}]"
        printf "║  %-37s ║\n" "6) Reasoning Mode     [${CFG_REASONING}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                echo "Modes: stream (RAM Shot + LRU) | sync | async | off"
                read -r -p "Enter mode: " val
                case "$val" in
                    stream|sync|async|off) config_set vitriol.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            2)
                read -r -p "Enter LRU cache MB (0-4096, 0=off): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 4096)); then
                    config_set vitriol.lru_mb "$val"
                else
                    echo "Invalid (must be 0-4096)"; sleep 1
                fi
                ;;
            3)
                if [[ "$CFG_VERBOSE" == "true" ]]; then
                    config_set vitriol.verbose "false"
                else
                    config_set vitriol.verbose "true"
                fi
                ;;
            4)
                if [[ "$CFG_PREDICTIVE_PREFETCH" == "on" ]]; then
                    config_set vitriol.predictive_prefetch "off"
                else
                    config_set vitriol.predictive_prefetch "on"
                fi
                ;;
            5)
                echo ""
                echo "Expert Pinning: permanently pins the full expert weight tensors"
                echo "of the first N layers into VRAM. Targets the fast MMVQ/MMQ/MMF path."
                echo ""
                echo "  Recommended: 5-15 layers (~220 MB per layer)"
                echo "  Auto-disables output cache (pinning + output cache target"
                echo "  different decode paths and do not stack)"
                echo ""
                echo "NOTE: Requires --kv-mode offload for >10 layers."
                echo "Not recommended with output cache enabled."
                echo ""
                read -r -p "Enter number of layers to pin (0=off, 1-40): " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 40)); then
                    config_set vitriol.pin_first_n_layers "$val"
                    if [[ "$val" -gt 0 ]]; then
                        echo ""
                        echo "  → Output cache has been disabled (pinning + output cache"
                        echo "    target different decode paths). You can re-enable it"
                        echo "    manually in Model Settings (option 6), but pinning will"
                        echo "    then only help during prefill, not decode."
                        config_set vitriol.output_cache "off"
                    fi
                else
                    echo "Invalid (must be 0-40)"; sleep 1
                fi
                ;;
            6)
                echo ""
                echo "Reasoning Mode: controls whether the model generates"
                echo "thinking/reasoning tokens before the response."
                echo ""
                echo "  Qwen3.6 models require 'off' to avoid garbled output."
                echo "  Other models: 'on' (auto-detect from template)."
                echo ""
                if [[ "$CFG_REASONING" == "off" ]]; then
                    config_set vitriol.reasoning "on"
                    echo "  → Reasoning set to on (auto-detect)"
                else
                    config_set vitriol.reasoning "off"
                    echo "  → Reasoning set to off (required for Qwen3.6)"
                fi
                sleep 1
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

tui_memory_menu() {
    while true; do
        clear
        print_header
        echo "╔══════════════════════════════════════════╗"
        echo "║          Context & Memory Settings       ║"
        echo "╠══════════════════════════════════════════╣"
        printf "║  %-37s ║\n" "1) Memory Mode      [${CFG_MEMORY_MODE}]"
        printf "║  %-37s ║\n" "2) KV Mode           [${CFG_KV_MODE}]"
        printf "║  %-37s ║\n" "3) Frozen Prompt     [${CFG_FROZEN_PROMPT}]"
        printf "║  %-37s ║\n" "4) Semantic Search   [${CFG_SEMANTIC_MODE}]"
        printf "║  %-37s ║\n" "5) K Cache Quant     [${CFG_KV_QUANT}]"
        printf "║  %-37s ║\n" "6) V Cache Quant     [${CFG_KV_QUANT_V}]"
        printf "║  %-37s ║\n" "7) Prompt Lookup     [${CFG_LOOKUP}]"
        printf "║  %-37s ║\n" "b) Back to Main Menu"
        printf "║  %-37s ║\n" "q) Quit"
        echo "╚══════════════════════════════════════════╝"
        echo ""
        read -r -p "Select [1-6/b/q]: " choice
        case "$choice" in
            1)
                echo "Modes: on (emulated memory) | off (direct)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set memory.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            2)
                echo "Modes: standard (default) | offload (system RAM) | sparse (attention eviction)"
                read -r -p "Enter mode: " val
                case "$val" in
                    standard|offload|sparse) config_set kv.mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            3)
                echo "Options: on (keep system prompt frozen) | off (default)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set frozen_prompt "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            4)
                echo "Options: on (semantic search via sentence-transformers) | off (keyword search)"
                read -r -p "Enter mode: " val
                case "$val" in
                    on|off) config_set memory.semantic_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            5)
                echo "K Cache quantization (affects K cache only; V cache configured separately)"
                echo "Options: f16 (FP16) | q8_0 (8-bit) | q4_0 (4-bit, recommended, max compression)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16|q8_0|q4_0) config_set kv.quant_mode "$val" ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            6)
                echo "V Cache quantization (RISK: quantizing V may produce garbage output)"
                echo "══════════════════════════════════════════════════════════════"
                echo "⚠  WARNING: --cache-type-v causes garbage output with VITRIOL"
                echo "   expert offloading. Only set to q8_0 or q4_0 if you have"
                echo "   verified it works correctly with your specific model."
                echo "══════════════════════════════════════════════════════════════"
                echo "Options: f16 (default, safe) | q8_0 (risky) | q4_0 (high risk)"
                read -r -p "Enter mode: " val
                case "$val" in
                    f16) config_set kv.quant_mode_v "$val" ;;
                    q8_0)
                        echo ""
                        echo "⚠  You selected q8_0 for V cache. This may cause garbage output."
                        read -r -p "Type YES to confirm: " confirm
                        [[ "$confirm" == "YES" ]] && config_set kv.quant_mode_v "$val" || echo "Cancelled"
                        sleep 2
                        ;;
                    q4_0)
                        echo ""
                        echo "⚠  You selected q4_0 for V cache. High risk of corruption."
                        read -r -p "Type YES to confirm: " confirm
                        [[ "$confirm" == "YES" ]] && config_set kv.quant_mode_v "$val" || echo "Cancelled"
                        sleep 2
                        ;;
                    *) echo "Invalid mode"; sleep 1 ;;
                esac
                ;;
            7)
                echo "Number of tokens to look ahead (0=disabled, 8-32 recommended)"
                read -r -p "Enter tokens: " val
                if [[ "$val" =~ ^[0-9]+$ ]] && ((val >= 0 && val <= 128)); then
                    config_set lookup_tokens "$val"
                else
                    echo "Invalid (must be 0-128)"; sleep 1
                fi
                ;;
            b|B) return ;;
            q|Q) clear; exit 0 ;;
        esac
    done
}

